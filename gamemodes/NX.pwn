		case DIALOG_HOSPITAL:
		{
			if(!response) return 1;

			foreach(new i : Player)
			{
				if(GetFactionType(i) == FACTION_MEDIC && PlayerInfo[i][pDuty] == 1)
				{
					return SCM(playerid, COLOR_ERROR, "EMS is currently on duty. Please wait for medical staff.");
				}
			}

			if(listitem == 0)
			{
				foreach(new i : Player)
				{
					if(PlayerInfo[i][pDraggedBy] == playerid)
					{
						return SCM(playerid, COLOR_ERROR, "You cannot check-in while carrying someone.");
					}
				}

				if(PlayerInfo[playerid][pCash] < 1000) return SCM(playerid, COLOR_SYNTAX, "You don't have enough money to pay bills.");
				
				GameTextForPlayer(playerid, "~g~Checking in...", 15000, 3);
				ApplyAnimation(playerid, "BD_FIRE", "wash_up", 4.1, 1, 0, 0, 0, 0, 1);
				TogglePlayerControllable(playerid, 0);
				SetTimerEx("Checkin", 15000, false, "i", playerid);

				GivePlayerCash(playerid, -7500);
				SendProximityMessage(playerid, 20.0, SERVER_COLOR, "**{C2A2DA} %s has paid a bill for his check in.", GetRPName(playerid));
			}
			else if(listitem == 1)
			{
				new bool:isCarrying = false;
				foreach(new i : Player)
				{
					if(PlayerInfo[i][pDraggedBy] == playerid)
					{
						isCarrying = true;
						break;
					}
				}

				if(isCarrying) 
				{
					return SCM(playerid, COLOR_ERROR, "You need to stop carrying the player before admitting them.");
				}
				ShowPlayerDialog(playerid, DIALOG_ADMIT, DIALOG_STYLE_INPUT, "Admit", "Enter the player id.", "Admit", "Back");
			}
		}
		case DIALOG_ADMIT:
		{
			if(!response) return 1;

			new targetid;

			if(sscanf(inputtext, "u", targetid)) 
			{
				return ShowPlayerDialog(playerid, DIALOG_ADMIT, DIALOG_STYLE_INPUT, "Admit", "Invalid ID.\nEnter the correct player id.", "Admit", "Back");
			}

			if(!IsPlayerConnected(targetid)) return SCM(playerid, COLOR_ERROR, "The specified player is not connected.");
			if(!IsPlayerInRangeOfPlayer(playerid, targetid, 7.0)) return SCM(playerid, COLOR_ERROR, "The player is too far away.");
			if(!PlayerInfo[targetid][pInjured]) return SCM(playerid, COLOR_ERROR, "This player is not injured.");
			if(targetid == playerid) return SCM(playerid, COLOR_ERROR, "You cannot admit yourself using this option.");

			PlayerInfo[targetid][pInjured] = 0;
			PlayerInfo[targetid][pHunger] = 50;
			PlayerInfo[targetid][pHungerTimer] = 0;
			PlayerInfo[targetid][pThirst] = 50;
			PlayerInfo[targetid][pThirstTimer] = 0;
			PlayerInfo[targetid][pDraggedBy] = INVALID_PLAYER_ID;

		    for(new i = 0; i < 18; i++)
		    {
		        PlayerTextDrawHide(targetid, InjuredTD[targetid][i]);
		    }

			new rand = random(sizeof(hospitalspawns));
			SetFreezePos(targetid, hospitalspawns[rand][0], hospitalspawns[rand][1], hospitalspawns[rand][2]);
			TogglePlayerControllable(targetid, 1);
			SetPlayerFacingAngle(targetid, 89.7591);
			SetPlayerInterior(targetid, 0);
			ClearAnimations(targetid, 1);
			SetPlayerVirtualWorld(targetid, 0);
			SetCameraBehindPlayer(targetid);
			SetPlayerHealth(targetid, 100.0);
			UpdateDynamic3DTextLabelText(InjuredLabel[targetid], COLOR_DOCTOR, "");

			new str[128];
			format(str, sizeof(str), "You have successfully admitted %s.", GetRPName(targetid));
			SCM(playerid, COLOR_DOCTOR, str);

			GivePlayerCash(targetid, -5000);
			SendProximityMessage(targetid, 20.0, SERVER_COLOR, "**{C2A2DA} %s has paid a bill for his checkin.", GetRPName(targetid));
			
			SCM(targetid, COLOR_DOCTOR, "You have been admitted to the hospital.");
			return 1;
		}
		case DIALOG_REVIVE:
		{
		    if(!response) return 1;

		    if(GetFactionType(playerid) != FACTION_POLICE)
		    {
		        return SCM(playerid, COLOR_ERROR, "You must be a Police Officer to use this medical equipment.");
		    }

		    new targetid;
		    if(sscanf(inputtext, "u", targetid))
		    {
		        return ShowPlayerDialog(playerid, DIALOG_REVIVE, DIALOG_STYLE_INPUT, "PD Field Revive", "Invalid ID.\nEnter the Suspect's ID or Name below:", "Revive", "Cancel");
		    }

		    if(!IsPlayerConnected(targetid))
		    {
		        return SCM(playerid, COLOR_ERROR, "The player is no longer connected.");
		    }

		    if(!IsPlayerInRangeOfPlayer(playerid, targetid, 5.0))
		    {
		        return SCM(playerid, COLOR_ERROR, "You are too far away from the suspect.");
		    }

		    if(!PlayerInfo[targetid][pInjured])
		    {
		        return SCM(playerid, COLOR_ERROR, "This player does not require medical attention.");
		    }

		    if(targetid == playerid)
		    {
		        return SCM(playerid, COLOR_ERROR, "You cannot use a field revive on yourself.");
		    }

		    new bool:isCarrying = false;
		    foreach(new i : Player)
		    {
		        if(PlayerInfo[i][pDraggedBy] == playerid)
		        {
		            isCarrying = true;
		            break;
		        }
		    }
		    if(isCarrying)
		        return SCM(playerid, COLOR_ERROR, "You cannot revive someone while you are dragging/carrying a body.");

		    PlayerInfo[targetid][pInjured] = 0;
		    PlayerInfo[targetid][pHunger] = 50;
		    PlayerInfo[targetid][pThirst] = 50;
		    PlayerInfo[targetid][pDraggedBy] = INVALID_PLAYER_ID;

		    for(new i = 0; i < 18; i++)
		    {
		        PlayerTextDrawHide(targetid, InjuredTD[targetid][i]);
		    }

		    TogglePlayerControllable(targetid, 1);
		    ClearAnimations(targetid, 1);
		    SetPlayerHealth(targetid, 100.0);
		    UpdateDynamic3DTextLabelText(InjuredLabel[targetid], COLOR_DOCTOR, "");

		    new str[144];
		    if(GetFactionType(targetid) != FACTION_POLICE)
		    {
		        PlayerInfo[targetid][pCuffed] = 1;
		        TogglePlayerControllable(targetid, 0);
		        ApplyAnimation(targetid, "ped", "cower", 4.1, 1, 1, 1, 1, 0);
		        format(str, sizeof(str), "You have successfully revived and cuffed %s.", GetRPName(targetid));
		        SCM(playerid, COLOR_DOCTOR, str);

		        format(str, sizeof(str), "Officer %s has revived and cuffed you. You are now in police custody.", GetRPName(playerid));
		        SCM(targetid, COLOR_DOCTOR, str);
		    }
		    else
		    {
		        format(str, sizeof(str), "You have successfully revived %s.", GetRPName(targetid));
		        SCM(playerid, COLOR_DOCTOR, str);

		        format(str, sizeof(str), "Officer %s has revived you.", GetRPName(playerid));
		        SCM(targetid, COLOR_DOCTOR, str);
		    }

		    SendProximityMessage(playerid, 20.0, SERVER_COLOR, "**{C2A2DA} %s opens a trauma kit and stabilizes %s.", GetRPName(playerid), GetRPName(targetid));

		    return 1;
		}
 		case DIALOG_TWEET:
		{
