CMD:mixcrack(playerid, const params[])
{
	if(gettime() - PlayerInfo[playerid][pProc1] < 16)
	{
	    return SM(playerid, COLOR_GREY, "You can only use job command in every 16 sec. Please wait %i more seconds.", 16 - (gettime() - PlayerInfo[playerid][pProc1]));
