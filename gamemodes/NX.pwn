	PlayerTextDrawSetProportional(playerid, TextDrawItemBox[playerid][i], true);
	PlayerTextDrawShow(playerid, TextDrawItemBox[playerid][i]);
	return true;
}

public EatingFood(playerid)
{
	PlayerInfo[playerid][pHunger] += 30;
	PlayerInfo[playerid][pHungerTimer] = 0;
	if (PlayerInfo[playerid][pHunger] > 100)
	{
		PlayerInfo[playerid][pHunger] = 100;
	}
	ClearAnimations(playerid);
	RemovePlayerAttachedObject(playerid, 0);
	SendProximityMessage(playerid, 20.0, COLOR_PURPLE, "** %s is done eating.", GetRPName(playerid));
	return 1;
}

stock ReturnName(playerid)
{
    new
        color, sz_playerName[MAX_PLAYER_NAME];

    if(!isnull(PlayerInfo[playerid][pUsername]))
    {
        if((color = GetPlayerColor(playerid)) == 0xFFFFFF00)
        {
            color = 0xAAAAAAFF;
        }
        format(sz_playerName, sizeof(sz_playerName), "{%06x}%s", color >>> 8, PlayerInfo[playerid][pUsername]);
    }
    else
    {
        GetPlayerName(playerid, sz_playerName, MAX_PLAYER_NAME);
    }
    return sz_playerName;
}

stock bool:IsValidGang(gangid)
{
    return (gangid > 0 && gangid < MAX_GANGS);
}

stock ClampInfluence(gangid)
{
    if (!IsValidGang(gangid)) return;

    if (GangInfo[gangid][gInfluence] < 0)
        GangInfo[gangid][gInfluence] = 0;
    else if (GangInfo[gangid][gInfluence] > 100)
        GangInfo[gangid][gInfluence] = 100;
}

EndTurf(turfid, progress)
{
    if (!TurfInfo[turfid][tExists])
        return 0;

    new captured = TurfInfo[turfid][tCapturedGang];
    new attacker = TurfInfo[turfid][tAttackingGang];
    new defender = TurfInfo[turfid][tDefendingGang];

    /* ---------------- ANNOUNCEMENTS ---------------- */

    if (progress == 1)
    {
        if (captured == defender && attacker != INVALID_GANG_ID)
        {
            /* ---- DEFENDED ---- */
            if (IsValidGang(captured))
            {
                if (IsValidGang(attacker))
                {
                    SMA(
                        COLOR_GREEN,
                        "%s has been successfully defended by %s from %s.",
                        TurfInfo[turfid][tName],
                        GangInfo[captured][gName],
                        GangInfo[attacker][gName]
                    );
                }
                else
                {
                    SMA(
                        COLOR_GREEN,
                        "%s has been successfully defended by %s from Police Dept.",
                        TurfInfo[turfid][tName],
                        GangInfo[captured][gName]
                    );
                }
            }
            else
            {
                SMA(
                    COLOR_GREEN,
                    "%s has been successfully defended by Police Dept.",
                    TurfInfo[turfid][tName]
                );
            }
        }
        else if (captured == attacker)
        {
            /* ---- CAPTURED ---- */
            if (IsValidGang(captured))
            {
                if (IsValidGang(defender))
                {
                    SMA(
                        COLOR_GREEN,
                        "%s has been claimed by %s from %s.",
                        TurfInfo[turfid][tName],
                        GangInfo[captured][gName],
                        GangInfo[defender][gName]
                    );
                }
                else
                {
                    SMA(
                        COLOR_GREEN,
                        "%s has been claimed by %s from Police Dept.",
                        TurfInfo[turfid][tName],
                        GangInfo[captured][gName]
                    );
                }
            }
            else
            {
                SMA(
                    COLOR_GREEN,
                    "%s has been claimed by Police Dept.",
                    TurfInfo[turfid][tName]
                );
            }
        }

        /* ---------------- REWARDS ---------------- */

        if (IsValidGang(captured))
        {
            switch (TurfInfo[turfid][tType])
            {
                case 1: SendGangMessage(captured, COLOR_YELLOW, "Your gang won the ownership of weed grinding turf!");
                case 2: SendGangMessage(captured, COLOR_YELLOW, "Your gang won the ownership of meth grinding turf!");
                case 3: SendGangMessage(captured, COLOR_YELLOW, "Your gang won the ownership of crack grinding turf!");
                case 4: SendGangMessage(captured, COLOR_YELLOW, "Your gang won the ownership of material grinding turf!");
                case 5: SendGangMessage(captured, COLOR_YELLOW, "Your gang won the ownership of money washing turf!");
                case 6:
                {
                    GangInfo[captured][gCrack] =
                        min(
                            GangInfo[captured][gCrack] + 10,
                            GetGangStashCapacity(captured, STASH_CAPACITY_COCAINE)
                        );

                    SendGangMessage(captured, COLOR_YELLOW,
                        "Your gang earned 10 grams of Crack in the stash for capturing this turf!");

                    mysql_format(connectionID, queryBuffer, sizeof queryBuffer,
                        "UPDATE gangs SET crack = %d WHERE id = %d",
                        GangInfo[captured][gCrack], captured);
                    mysql_tquery(connectionID, queryBuffer);
                }
                case 7:
                {
                    SendGangMessage(captured, COLOR_YELLOW,
                        "Your gang will now receive 10 percent of all sales in this turf.");
                }
                case 8:
                {
                    GangInfo[captured][gWeapons][GANGWEAPON_9MM] += 4;
                    GangInfo[captured][gWeapons][GANGWEAPON_SHOTGUN] += 2;
                    GangInfo[captured][gWeapons][GANGWEAPON_RIFLE] += 2;

                    SendGangMessage(captured, COLOR_YELLOW,
                        "Your gang earned 9mm(4), Shotgun(2), Rifle(2) in its stash!");

                    mysql_format(connectionID, queryBuffer, sizeof queryBuffer,
                        "UPDATE gangs SET weapon_9mm=%d, weapon_shotgun=%d, weapon_rifle=%d WHERE id=%d",
                        GangInfo[captured][gWeapons][GANGWEAPON_9MM],
                        GangInfo[captured][gWeapons][GANGWEAPON_SHOTGUN],
                        GangInfo[captured][gWeapons][GANGWEAPON_RIFLE],
                        captured);
                    mysql_tquery(connectionID, queryBuffer);
                }
            }
        }

        mysql_format(connectionID, queryBuffer, sizeof queryBuffer,
            "UPDATE turfs SET capturedgang = %d WHERE id = %d",
            captured, turfid);
        mysql_tquery(connectionID, queryBuffer);
    }
    else
    {
        SMA(COLOR_LIGHTRED, "%s has been ended by an administrator.", TurfInfo[turfid][tName]);
    }

    /* ---------------- HIDE HUD ---------------- */

    foreach (new i : Player)
    {
        if (PlayerInfo[i][pLogged] && GetNearbyTurf(i) == turfid)
        {
            HideTurfTD(i);
        }
    }

    /* ---------------- RESET TURF STATE ---------------- */

    TurfInfo[turfid][tCapturing]      = 0;
    TurfInfo[turfid][tCaptureTime]    = 0;
    TurfInfo[turfid][tCaptureSeconds] = 0;
    TurfInfo[turfid][tTime]           = 48;
    TurfInfo[turfid][tAttackingGang]  = INVALID_GANG_ID;
    TurfInfo[turfid][tDefendingGang]  = INVALID_GANG_ID;

    mysql_format(connectionID, queryBuffer, sizeof queryBuffer,
        "UPDATE turfs SET time = %d WHERE id = %d",
        TurfInfo[turfid][tTime], turfid);
    mysql_tquery(connectionID, queryBuffer);

    ReloadTurf(turfid);

    return 1;
}

stock TurfCheck()
{
    for(new i = 0; i < MAX_TURFS; i++)
    {
        if (!TurfInfo[i][tExists]) continue;
        if (!TurfInfo[i][tCapturing]) continue;

        /* ---------------- CAPTURE TIMER ---------------- */

        if (TurfInfo[i][tCaptureSeconds] > 0)
        {
            TurfInfo[i][tCaptureSeconds]--;

            if (TurfInfo[i][tCaptureSeconds] <= 0 && TurfInfo[i][tCaptureTime] > 0)
            {
                TurfInfo[i][tCaptureTime]--;
                TurfInfo[i][tCaptureSeconds] = 60;
            }

            if (TurfInfo[i][tCaptureTime] <= 0 && TurfInfo[i][tCaptureSeconds] <= 0)
            {
                EndTurf(i, 1);
                continue;
            }
        }

        /* ---------------- RESET ATTACK COUNTS ---------------- */

		for(new k = 0; k < MAX_GANGS; k++)
        {
            TurfAttackerCount[i][k] = 0;
        }

        TurfAttackerCount[i][0] = 0; // police bucket

        /* ---------------- PLAYER LOOP ---------------- */

        foreach (new j : Player)
        {
            if (GetNearbyTurf(j) != i) continue;

            /* ---- HUD / TEXTDRAWS ---- */

            new string[64];

            if (TurfInfo[i][tCapturedGang] == 0)
            {
                PlayerTextDrawSetString(j, TurfTextDraw[j][0], "Control: Police Dept");
				PlayerTextDrawColour(j, TurfTextDraw[j][0], (COLOR_BLUE & ~0xff) + 0xFF);

                PlayerTextDrawSetString(j, TurfTextDraw[j][1], "~y~Influence: ~w~N/A");
            }
            else if (IsValidGang(TurfInfo[i][tCapturedGang]))
            {
                format(string, sizeof string, "Control: %s",
                    GangInfo[TurfInfo[i][tCapturedGang]][gName]);
                PlayerTextDrawSetString(j, TurfTextDraw[j][0], string);
                PlayerTextDrawColour(j, TurfTextDraw[j][0],
                    (GangInfo[TurfInfo[i][tCapturedGang]][gColor] & ~0xff) + 0xFF);

                format(string, sizeof string, "~y~Influence: ~w~%d",
                    GangInfo[TurfInfo[i][tCapturedGang]][gInfluence]);
                PlayerTextDrawSetString(j, TurfTextDraw[j][1], string);
            }

            format(string, sizeof string, "~y~Time: ~w~%02d:%02d",
                TurfInfo[i][tCaptureTime],
                TurfInfo[i][tCaptureSeconds]);
            PlayerTextDrawSetString(j, TurfTextDraw[j][2], string);

            /* ---- ATTACKER COUNTING ---- */

            if (PlayerInfo[j][pInjured] || PlayerInfo[j][pAdminDuty])
                continue;

            if (PlayerInfo[j][pGang] > 0 &&
                PlayerInfo[j][pGang] != TurfInfo[i][tCapturedGang])
            {
                TurfAttackerCount[i][PlayerInfo[j][pGang]]++;
            }
            else if (IsLawEnforcement(j) && TurfInfo[i][tCapturedGang] != 0)
            {
                TurfAttackerCount[i][0]++;
            }
        }

        /* ---------------- DETERMINE ATTACKING GANG ---------------- */

        new gangid = INVALID_GANG_ID;

		for(new k = 0; k < MAX_GANGS; k++)
        {
            if (TurfAttackerCount[i][k] > 0)
            {
                gangid = k;
                break;
            }
        }

        if (gangid != INVALID_GANG_ID)
        {
			for(new k = 0; k < MAX_GANGS; k++)
            {
                if (TurfAttackerCount[i][k] > TurfAttackerCount[i][gangid])
                {
                    gangid = k;
                }
            }

            TurfInfo[i][tAttackingGang] = gangid;

            foreach (new j : Player)
            {
                if (PlayerInfo[j][pShowTurfs])
                {
                    ShowTurfsOnMap(j, true);
                }
            }
        }
        else
        {
            TurfInfo[i][tAttackingGang] = INVALID_GANG_ID;
        }
    }
}

forward InfluenceCheck();
public InfluenceCheck()
{
	for(new i = 0; i < MAX_TURFS; i++)
	{
		if (!TurfInfo[i][tExists]) continue;
		if (!TurfInfo[i][tCapturing]) continue;

		new attackers = 0, defenders = 0;

		new atkGang = TurfInfo[i][tAttackingGang];
		new defGang = TurfInfo[i][tDefendingGang];

		// --- Count players in turf ---
		foreach (new j : Player)
		{
			if (PlayerInfo[j][pInjured]) continue;
			if (PlayerInfo[j][pAdminDuty]) continue;
			if (GetNearbyTurf(j) != i) continue;

			// attackers
			if (atkGang == 0)
			{
				if (IsLawEnforcement(j)) attackers++;
			}
			else if (IsValidGang(atkGang) && PlayerInfo[j][pGang] == atkGang)
			{
				attackers++;
			}

			// defenders
			if (defGang == 0)
			{
				if (IsLawEnforcement(j)) defenders++;
			}
			else if (IsValidGang(defGang) && PlayerInfo[j][pGang] == defGang)
			{
				defenders++;
			}
		}

		// --- DRAW STATE ---
		if (attackers == defenders)
			continue;

		// --- DEFENDERS WIN ---
		if (defenders > attackers)
		{
			if (TurfInfo[i][tCapturedGang] == defGang)
			{
				if (IsValidGang(defGang))
				{
					GangInfo[defGang][gInfluence]++;
					ClampInfluence(defGang);
				}

				if (IsValidGang(atkGang))
				{
					GangInfo[atkGang][gInfluence]--;
					ClampInfluence(atkGang);
				}
			}
			else
			{
				if (IsValidGang(atkGang))
				{
					GangInfo[atkGang][gInfluence]--;
					ClampInfluence(atkGang);

					if (GangInfo[atkGang][gInfluence] == 0)
					{
						TurfInfo[i][tCapturedGang] = defGang;

						SAM(
							COLOR_GREEN,
							"[Turf News]: "WHITE"%s is now in control of %s",
							GangInfo[defGang][gName],
							TurfInfo[i][tName]
						);

						if (IsValidGang(defGang))
						{
							GangInfo[defGang][gInfluence]++;
							ClampInfluence(defGang);
						}

						EndTurf(i, 0);
					}
				}
			}
		}
		// --- ATTACKERS WIN ---
		else
		{
			if (TurfInfo[i][tCapturedGang] == atkGang)
			{
				if (IsValidGang(atkGang))
				{
					GangInfo[atkGang][gInfluence]++;
					ClampInfluence(atkGang);

					if (GangInfo[atkGang][gInfluence] >= 100)
					{
						EndTurf(i, 1);
					}
				}

				if (IsValidGang(defGang))
				{
					GangInfo[defGang][gInfluence]--;
					ClampInfluence(defGang);
				}
			}
			else
			{
				if (IsValidGang(defGang))
				{
					GangInfo[defGang][gInfluence]--;
					ClampInfluence(defGang);

					if (GangInfo[defGang][gInfluence] == 0)
					{
						TurfInfo[i][tCapturedGang] = atkGang;

						SAM(
							COLOR_GREEN,
							"[Turf News]: "WHITE"%s is now in control of %s",
							GangInfo[atkGang][gName],
							TurfInfo[i][tName]
						);

						if (IsValidGang(atkGang))
						{
							GangInfo[atkGang][gInfluence]++;
							ClampInfluence(atkGang);
						}

						EndTurf(i, 1);
					}
				}
			}
		}
	}
}

public Drinkingwater(playerid)
{
	PlayerInfo[playerid][pThirst] += 30;
	PlayerInfo[playerid][pThirstTimer] = 0;
	if (PlayerInfo[playerid][pThirst] > 100)
	{
		PlayerInfo[playerid][pThirst] = 100;
	}
	ClearAnimations(playerid);
	RemovePlayerAttachedObject(playerid, 1);
	SendProximityMessage(playerid, 20.0, COLOR_PURPLE, "** %s is done drinking.", GetRPName(playerid));
	return 1;
}

public TimerRepairkit(playerid)
{
    new vehicleid = GetNearbyVehicle(playerid);
    RepairVehicle(vehicleid);
    SCM(playerid, COLOR_WHITE, "You have repaired the vehicle you're riding...");
    TogglePlayerControllable(playerid, true);
	SetVehicleHealth(vehicleid, 1000.0);
	SendProximityMessage(playerid, 20.0, COLOR_PURPLE, "** %s successfully repaired his/her vehicle.", GetRPName(playerid));
	PlayerPlaySound(playerid, 1133, 0.0, 0.0, 0.0);
	ClearAnimations(playerid, true);
	return 1;
}

public OnPlayerAirbreak(playerid)
{
	if((gAnticheat) && PlayerInfo[playerid][pAdmin] < 2 && !PlayerInfo[playerid][pKicked])
	{
	    if(PlayerInfo[playerid][pACWarns] < MAX_ANTICHEAT_WARNINGS)
	    {
	        SAM(COLOR_YELLOW, "AdmWarning: %s[%i] is possibly using airbreak hacks.", GetRPName(playerid), playerid);
		}
	}
	return 1;
}

