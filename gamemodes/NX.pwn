	gPrisonCells[15] = CreateDynamicObject(19302,1205.69995117,-1337.69995117,800.50000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[16] = CreateDynamicObject(19302,1205.69995117,-1340.90002441,800.50000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[17] = CreateDynamicObject(19302,1205.69995117,-1334.50000000,797.00000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[18] = CreateDynamicObject(19302,1205.69995117,-1337.69995117,797.00000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[19] = CreateDynamicObject(19302,1205.69995117,-1340.90002441,797.00000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[20] = CreateDynamicObject(19302,1215.30004883,-1344.09997559,800.50000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[21] = CreateDynamicObject(19302,1215.30004883,-1344.09997559,797.00000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[22] = CreateDynamicObject(19302,1205.69995117,-1344.09997559,800.50000000,0.00000000,0.00000000,90.00000000);
	gPrisonCells[23] = CreateDynamicObject(19302,1205.69995117,-1344.09997559,797.00000000,0.00000000,0.00000000,90.00000000);

	for(new i = 0; i < 24; i ++)
	{
		SetDynamicObjectMaterial(gPrisonCells[i], 0, 19302, "pd_jail_door02", "pd_jail_door02", 0xFF000000);
	}

	gettime(.hour = gHour);
 	gettime(.hour = gWorldTime);
	SetWorldTime(gWorldTime);

	for(new i = 0; i < MAX_LANDS; i ++)
	{
	    ReloadAllLandObjects(i);
	    ReloadLand(i);
	}

	// Timers
	SetTimer("MinuteTimer", 60000, true);
	SetTimer("SecondTimer", 1000, true);
	SetTimer("VehicleTimer", 100, true);
	SetTimer("InfluenceCheck", 3000, true);
	SetTimer("FuelTimer", 75000, true);
	SetTimer("InjuredTimer", 5000, true);
	SetTimer("LotteryUpdate", 2700000, true);
	SetTimerEx("RandomFire", 7200000, true, "i", 1);
	SetTimer("SaveAccount", 1000, true);
    SetTimer("OnTRWeedCheckState", 5000, true);
    SetTimer("UpdateBotStatus", 10000, true);

	// Misc
    LoadServerInfo();
    RefreshTime();
    ResetEvent();
    ResetRobbery();
    ResetRob();
	gLastSave = 0;
	gLastFix = 0;

	print(SERVER_NAME);

	new count;
	for(new i = 0; i < MAX_OBJECTS; i ++)
	{
	    if(IsValidObject(i)) count++;
	}

	printf("%i objects loaded.", count);
	return 1;
}

public OnGameModeExit()
{
    for(new i = 0; i < MAX_PLAYERS+1; i++) if(IsPlayerConnected(i)) if(!IsPlayerNPC(i))	for(new a = 0; a < 10; a++)	if(IsPlayerAttachedObjectSlotUsed(i, a)) RemovePlayerAttachedObject(i, a);

    // FPS - Display
	TextDrawDestroy(FPSDisplayTD[0]);
	TextDrawDestroy(FPSDisplayTD[1]);
	TextDrawDestroy(FPSDisplayTD[2]);
	TextDrawDestroy(FPSDisplayTD[3]);
	TextDrawDestroy(FPSDisplayTD[4]);
	TextDrawDestroy(FPSDisplayTD[5]);

    for(new o=0; o<MAX_STATIC_OBJECTS; o++)
	{
	    DestroyObject(o);
	}

	for(new i = 0; i < MAX_OBJECTS; i ++)
	{
	    if(IsValidObject(i) && gScriptObject{i})
	    {
	        DestroyObject(i);
		}
	}

	KillTimer(FlashTimer);
	mysql_close(connectionID);

	// CCTV
	TextDrawHideForAll(TD);
	TextDrawDestroy(TD);

	for(new i; i<TotalMenus; i++)
	{
		DestroyMenu(CCTVMenu[i]);
	}

	if(gDoubleXP)
	{
	    gDoubleXP = 0;
	}
	
	if(gRobbery)
	{
		gRobbery = 0;
	}

	if(gDoubleSalary)
	{
	    gDoubleSalary = 0;
	}

	for (new i = 0; i < MAX_PLAYERS; i++)
    {
        if (ChannelText[i] != Text:INVALID_TEXT_DRAW)
        {
            TextDrawDestroy(ChannelText[i]);
            ChannelText[i] = Text:INVALID_TEXT_DRAW;
        }
    }
    if (TimerUpdate != INVALID_TIMER)
    {
        KillTimer(TimerUpdate);
        TimerUpdate = INVALID_TIMER;
    }

	return 1;
}

public OnPlayerConnect(playerid)
{
    if(gDisabledVPN)
	{
		new formato[59];
		format(formato, sizeof formato, "www.shroomery.org/ythan/proxycheck.php?ip=%s", GetPlayerIP(playerid));
		HTTP(playerid, HTTP_GET, formato, "", "HTTP_ProxyCheck");
	}

    if (SvGetVersion(playerid) == SV_NULL)
    {
        SendClientMessage(playerid, -1, "The plugin sampvoice could not be found.");
    }
    else if (SvHasMicro(playerid) == SV_FALSE)
    {
        SendClientMessage(playerid, -1, "The microphone could not be found.");
    }
    else if ((lstream[playerid] = SvCreateDLStreamAtPlayer(15.0, SV_INFINITY, playerid, SERVER_COLOR, "Local")))
    {
        SvAddKey(playerid, 0x42);
        SvAddKey(playerid, 0x5A);
    }

	MaxPlayerNotify[playerid] = 0;
    IndexNotify[playerid] = 0;
    
    for(new i = 0; i < 70; i++) 
    {
        NotifyTD[playerid][i] = PlayerText:INVALID_TEXT_DRAW;
    }

	SCM(playerid, COLOR_SAMP, "Connecting to the database of "SVRCLR""SERVER_NAME".");

	RadioChannel[playerid] = INVALID_CHANNEL;
    IsPlayerMicOn[playerid] = 0;
    ChannelText[playerid] = Text:INVALID_TEXT_DRAW;

    new string[256], ip[16], version[32], device[64];
    GetPlayerIp(playerid, ip, sizeof(ip));
    GetPlayerVersion(playerid, version, sizeof(version));
    format(device, sizeof(device), "SA-MP Client (%s)", version);

	new name[MAX_PLAYER_NAME];
	format(name, sizeof(name), "%s", GetRPName(playerid));

	new DCC_Embed:embed = DCC_CreateEmbed();
	DCC_SetEmbedTitle(embed, "Player Connected");
	format(string, sizeof(string), "%s has joined Nexonic Roleplay.", name);
	DCC_SetEmbedDescription(embed, string);
	DCC_SetEmbedColor(embed, 0x00FF00);
	DCC_SetEmbedThumbnail(embed, "https://i.postimg.cc/sxfVT479/logo.png");
	DCC_AddEmbedField(embed, "Player Name", name, true);
	DCC_AddEmbedField(embed, "IP Address", ip, true);
	DCC_AddEmbedField(embed, "Client Version", version, true);
	DCC_SetEmbedFooter(embed, "Nexonic Roleplay", "");
	DCC_SendChannelEmbedMessage(loginlogs, embed);

	UpdateBotStatus();

	for(new c = 0; c < 10; c++)
	{
	    PlayerInfo[playerid][pCowCooldown][c] = 0;
	}

    ExBJck[playerid] = 0;
    pBlind[playerid] = 0;
    Maskara[playerid] = 0;
    MaskaraID[playerid] = 0;
    ShowingBounds[playerid] = 0;
	Sliding[playerid] = 0;
    InsideTut[playerid] = 0;
    CurrentCCTV[playerid] = -1;
	pvehicleid[playerid] = GetPlayerVehicleID(playerid);
	pvehicleid[playerid] = 0;
    pmodelid[playerid] = 0;
	PayCheckCode[playerid] = 0;
	PowerSpec[playerid] = 0;

	// Default values are handled via MySQL/PhpMyAdmin. Don't assign default values here.
	PlayerInfo[playerid][pRobbingHouse] = -1;
	PlayerInfo[playerid][pToolkit] = 0;
	PlayerInfo[playerid][pRepairKit] = 0;
