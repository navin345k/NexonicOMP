	return 1;
}

CMD:cookmeths(playerid, const params[])
{
	if(gettime() - PlayerInfo[playerid][pProc1] < 11)
	{
	    return SM(playerid, COLOR_GREY, "You can only use job command in every 11 sec. Please wait %i more seconds.", 11 - (gettime() - PlayerInfo[playerid][pProc1]));
	}
	if(!PlayerInfo[playerid][pEphedrine])
	{
		SM(playerid, COLOR_GREY, "You don't have any raw ephedrine which you could turn into meth.");
		return 1;
	}
	if(!PlayerInfo[playerid][pMuriaticAcid])
	{
		SM(playerid, COLOR_GREY, "You need muriatic acid in order to cook meth. Go buy some at 24/7.");
		return 1;
	}
	if(!PlayerInfo[playerid][pBakingSoda])
	{
		SM(playerid, COLOR_GREY, "You need baking soda in order to cook meth. Go buy some at 24/7.");
		return 1;
	}
	if(PlayerInfo[playerid][pGang] == -1)
	{
		return SM(playerid, COLOR_GREY, "You can't use this command as you're not a gang member.");
	}
	if(!IsPlayerInRangeOfPoint(playerid, 10.0, -285.899108, -771.502929, 3674.529052) || !IsPlayerInRangeOfPoint(playerid, 10.0, -280.533447, -771.382812, 3674.529052) || !IsPlayerInRangeOfPoint(playerid, 10.0, -280.305877, -778.026794, 3674.529052))
	{
	    return SM(playerid, COLOR_GREY, "You are not inside of the meth grinding turf.");
	}
	if(!PlayerInfo[playerid][pCookMeth])
	{
		if(!PlayerInfo[playerid][pEphedrine])
		{
			SM(playerid, COLOR_GREY, "You don't have any raw ephedrine which you could turn into meth.");
	    	return 1;
		}
	    if(!PlayerInfo[playerid][pMuriaticAcid])
	    {
	        SM(playerid, COLOR_GREY, "You need muriatic acid in order to cook meth. Go buy some at 24/7.");
			return 1;
		}
 	    if(!PlayerInfo[playerid][pBakingSoda])
	    {
	        SM(playerid, COLOR_GREY, "You need baking soda in order to cook meth. Go buy some at 24/7.");
			return 1;
		}
		PlayerInfo[playerid][pCookMeth] = 1;
		PlayerInfo[playerid][pCookTime] = 15;
		PlayerInfo[playerid][pCookGrams] = 0;
		PlayerInfo[playerid][pProc1] = gettime();
		
		ApplyAnimationEx(playerid, "BD_FIRE", "wash_up", 4.0, 1, 1, 1, 0, 0);

		SM(playerid, COLOR_GREY, "You have started cooking meth. 2 gram of ephedrine will turn into 2 gram of meth every 15 seconds.");
	    SM(playerid, COLOR_GREY, "Type the /cookmeth command again in order to stop cooking.");
	}
	else
	{
	    SM(playerid, COLOR_AQUA, "You have stopped cooking. You converted %i grams of ephedrine into %i grams of cooked meth.", PlayerInfo[playerid][pCookGrams] / 2, PlayerInfo[playerid][pCookGrams]);
	    ResetCooking(playerid);
	}
	return 1;
}

