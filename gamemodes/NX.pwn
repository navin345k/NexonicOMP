		case DIALOG_ATM_TRANSFER_ID:
		{
			new string[255];
			if(response)
			{
				if(!IsNumeric(inputtext) || !strlen(inputtext))
					return ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER_ID);

				new giveplayerid;
				if(!IsPlayerConnected(giveplayerid)) {
					SendClientMessageEx(playerid, COLOR_GREY, "Invalid player specified, not connected try again.");
					return ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER_ID);
				}

				if(!IsPlayerConnected(giveplayerid))
				{
					SendClientMessageEx(playerid, COLOR_GREY, "Player has not logged in yet.");
					return ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER_ID);
				}

				SetPVarInt(playerid, "transferID", giveplayerid);
				format(string, sizeof(string), "You current have: $%s.\n\nHow much money do you want to send to ID: %d.", FormatNumber(PlayerInfo[playerid][pBank])), GetPVarInt(playerid, "transferID");
				ShowPlayerDialog(playerid, DIALOG_ATM_TRANSFER_AMOUNT, DIALOG_STYLE_INPUT, "{33AA33}ATM | Transfer Amount", string, "Transfer", "Back");

			}
		}
		case DIALOG_ATM_TRANSFER_AMOUNT:
		{
			if(response)
			{
				if(PlayerInfo[playerid][pLevel] < 2)
				{
					return SCM(playerid, COLOR_WHITE, "You must be level 2 before you access this feature...");
				}
				new amount = strval(inputtext), giveplayerid = GetPVarInt(playerid, "transferID");
				new playermoney = PlayerInfo[playerid][pBank];

				if(!IsPlayerConnected(GetPVarInt(playerid, "transferID"))) {
					SendClientMessageEx(playerid, COLOR_GREY, "The player you are sending your money to has disconnected from the server.");
					return 	ShowPlayerDialog(playerid, DIALOG_ATM_TRANSFER_ID, DIALOG_STYLE_INPUT, "{33AA33}ATM | Transfer ID", "Please input the ID of the person you want to send the money to:", "Proceed", "Back");
				}
				new string[255];
				if(!IsNumeric(inputtext) || !strlen(inputtext))
					return 	format(string, sizeof(string), "You current have: $%s.\n\nHow much money do you want to send to ID: %d.", number_format(PlayerInfo[playerid][pBank]), GetPVarInt(playerid, "transferID"));
				ShowPlayerDialog(playerid, DIALOG_ATM_TRANSFER_AMOUNT, DIALOG_STYLE_INPUT, "{33AA33}ATM | Transfer Amount", string, "Transfer", "Back");


				if (amount > 0 && playermoney >= amount)
				{
					if(PlayerInfo[playerid][pVIPPackage] == 0)
					{
						new fee;
						fee = 3*amount/100;
						PlayerInfo[playerid][pBank]=PlayerInfo[playerid][pBank]-fee;
						format(string, sizeof(string), "-$%d money (3 percent fee).\n", fee);
					}

					PlayerInfo[playerid][pBank] -= amount;
					PlayerInfo[giveplayerid][pBank] += amount;

					Log_Write("log_give", "%s has transfer $%s to %s, their balance now is: $%s", GetRPName(playerid), number_format(amount), GetRPName(giveplayerid), number_format(PlayerInfo[playerid][pBank]));

		            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bank = %i WHERE uid = %i", PlayerInfo[playerid][pBank], PlayerInfo[playerid][pID]);
		            mysql_tquery(connectionID, queryBuffer);
		            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bank = %i WHERE uid = %i", PlayerInfo[giveplayerid][pBank], PlayerInfo[giveplayerid][pID]);
		            mysql_tquery(connectionID, queryBuffer);

					format(string, sizeof(string), "%sTransfer Amount: $%s\n", string, number_format(amount));
					format(string, sizeof(string), "%sTransfer to: %s [ID: %d]", string, GetRPName(giveplayerid), giveplayerid);
					format(string, sizeof(string), "%s\n\n{FFFFFF}Your account balance is now {33AA33}$%s{FFFFFF}.", string, number_format(PlayerInfo[playerid][pBank]));
					ShowPlayerDialog(playerid, DIALOG_ATM_TRANSFER_INFO, DIALOG_STYLE_MSGBOX, ""SVRCLR"ATM | Transfer Info", string, "Proceed", "");
					PlayerPlaySound(playerid, 1052, 0.0, 0.0, 0.0);
					new titlestring[128];
					format(titlestring, sizeof(titlestring), "You have recieved $%s to into your account from %s.", number_format(amount), GetRPName(playerid));
					SendClientMessageEx(giveplayerid, COLOR_TWEET, titlestring);
					PlayerPlaySound(giveplayerid, 1052, 0.0, 0.0, 0.0);

					new ip[32], ipex[32];
					GetPlayerIp(playerid, ip, sizeof(ip));
					GetPlayerIp(giveplayerid, ipex, sizeof(ipex));
		    		SAM(COLOR_YELLOW, "AdmWarning: %s has transferred $%i to %s.", GetRPName(playerid), amount, GetRPName(giveplayerid));
					Log_Write("log_give", "%s (uid: %i) (IP: %s) transferred $%i to %s (uid: %i) (IP: %s)", GetRPName(playerid), PlayerInfo[playerid][pID], GetPlayerIP(playerid), amount, GetRPName(giveplayerid), PlayerInfo[giveplayerid][pID], GetPlayerIP(giveplayerid));
				}
				else
				{
					SendClientMessageEx(playerid, COLOR_TWEET, "   Invalid transaction amount.");
				}
			}
			else
			{
				DeletePVar(playerid, "transferID");
				ShowPlayerDialog(playerid, DIALOG_ATM_TRANSFER_ID, DIALOG_STYLE_INPUT, "{33AA33}ATM | Transfer ID", "Please input the ID of the person you want to send the money to:", "Proceed", "Back");
			}
		}
	    case DIALOG_ATM_TRANSFER2:
	    {
	        if(response)
	        {
	            new id = GetPVarInt(playerid, "transfer_id"), amount, fee;
	            new targetid;

	            if(sscanf(inputtext, "i", amount))
	            {
					return ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER2);
	            }
	            if(amount < 1 || amount > PlayerInfo[playerid][pBank])
	            {
	                SendClientMessage(playerid, COLOR_GREY, "Insufficient amount. Please try again.");
	                ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER2);
	                return 1;
	            }
	            if(amount > 1000000)
	            {
	                SendClientMessage(playerid, COLOR_GREY, "You can't withdraw more than $1,000,000 at a time.");
	                ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER2);
	                return 1;
	            }
				if(!IsPlayerConnected(id))
				{
					DeletePVar(playerid, "transfer_id");
	                SendClientMessage(playerid, COLOR_GREY, "The player that you are trying to transfer the money to has disconnected.");
	                ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER);
					return 1;
				}
				if(!PlayerInfo[id][pLogged])
				{
					DeletePVar(playerid, "transfer_id");
	                SendClientMessage(playerid, COLOR_ERROR, "(( That player is not logged in ))");
	                ShowDialogToPlayer(playerid, DIALOG_ATM_TRANSFER);
					return 1;
				}

	            PlayerInfo[playerid][pBank] -= amount;
	            PlayerInfo[id][pBank] += amount;
				PlayerInfo[playerid][pLastTransfer] = amount;

	            if(PlayerInfo[playerid][pVIPPackage] == 0)
	            {
	                fee = percent(amount, 3);

	                PlayerInfo[playerid][pBank] -= fee;
	            }

				for(new j = 0; j < 78; j++) 
				{
					TextDrawHideForPlayer(playerid, NexBank[j]);
				}
				for(new j = 0; j < 5; j++)
				{
					PlayerTextDrawHide(playerid, BANKTD[playerid][j]);
				}
				CancelSelectTextDraw(playerid);

	            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bank = %i WHERE uid = %i", PlayerInfo[playerid][pBank], PlayerInfo[playerid][pID]);
	            mysql_tquery(connectionID, queryBuffer);
	            mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bank = %i WHERE uid = %i", PlayerInfo[id][pBank], PlayerInfo[id][pID]);
	            mysql_tquery(connectionID, queryBuffer);

	            SendProximityMessage(playerid, 20.0, COLOR_GLOBAL, "**{C2A2DA} %s presses a button transferring some cash to someone.", GetRPName(playerid));
	            SM(targetid, COLOR_GREEN, "** %s has Wiretransferred $%i to your bank account.", GetRPName(playerid), amount);

				new xyzString[128];
				format(xyzString, sizeof(xyzString), "You have transferred %s to %s. Your new balance is %s.", FormatNumber(amount), GetRPName(id), FormatNumber(PlayerInfo[playerid][pBank]));
				ShowInfo(playerid, xyzString);

				if(fee)
				{
				    SM(playerid, COLOR_WHITE, "A 3 percent convenience fee of %s was deducted from your bank account.", FormatNumber(fee));
				    AddToTaxVault(fee);
	            }
	            else if(PlayerInfo[playerid][pVIPPackage] > 0)
	            {
					SendClientMessage(playerid, COLOR_VIP, "DONATOR Perk: You do not pay the 3 percent convenience fee as you are a Donator!");
	            }
	        }
		}
