{
	switch(GetVehicleModel(carid)) {
		case 509, 510, 462, 448, 581, 522, 461, 521, 523, 463, 586, 468, 471: return 1;
	}
	return 0;
}

forward FlasherFunc();
public FlasherFunc() {
	new panelsx,doorsx,lightsx,tiresx;
	for (new p=0; p<MAX_VEHICLES; p++)
	{
		if (Flasher[p] == 1)
		{
			if (FlasherState[p] == 1)
			{
				GetVehicleDamageStatus(p,panelsx,doorsx,lightsx,tiresx);
				UpdateVehicleDamageStatus(p, panelsx, doorsx, 4, tiresx);
				FlasherState[p] = 0;
			}
			else
			{
				GetVehicleDamageStatus(p,panelsx,doorsx,lightsx,tiresx);
				UpdateVehicleDamageStatus(p, panelsx, doorsx, 1, tiresx);
				FlasherState[p] = 1;
			}
		}
	}
	return 1;
}

forward ProgressLoader(playerid);
public ProgressLoader(playerid)
{
    for(new i = 0; i < 11; i++)
    {
        PlayerTextDrawShow(playerid, NexIntro[playerid][i]);
    }
    PlayerTextDrawShow(playerid, NexIntroProg[playerid][0]);

    LoadPercent[playerid] = 0.0;
    LoadStage[playerid] = 0;

    zloadbar[playerid] = CreatePlayerProgressBar(playerid, 186.0, 298.0, 238.5, 4.0, -1724670878, 100.0, BAR_DIRECTION_RIGHT);
    SetPlayerProgressBarMaxValue(playerid, zloadbar[playerid], 100.0);
    SetPlayerProgressBarValue(playerid, zloadbar[playerid], 0.0);
    ShowPlayerProgressBar(playerid, zloadbar[playerid]);

    zTimerLoadscreen[playerid] = SetTimerEx("zintrotimer", 500, true, "i", playerid);
}

forward zintrotimer(playerid);
public zintrotimer(playerid)
{
    if(!IsPlayerConnected(playerid)) return 1;

    LoadPercent[playerid] += 2.5;

    if(LoadPercent[playerid] <= 100.0)
    {
        SetPlayerProgressBarValue(playerid, zloadbar[playerid], LoadPercent[playerid]);

        LoadStage[playerid]++;

        switch(LoadStage[playerid])
        {
            case 4:  PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "../plugins/log-core...");
            case 8:  PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "../plugins/scanff2...");
            case 12: PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "../plugins/streamer...");
            case 16: PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "../plugins/nx-status...");
            case 20: PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "Loading...");
            case 30: PlayerTextDrawSetString(playerid, NexIntroProg[playerid][0], "__Connected Successfully...");
        }
    }
    else
    {
        HidePlayerProgressBar(playerid, zloadbar[playerid]);
        DestroyPlayerProgressBar(playerid, zloadbar[playerid]);
        zloadbar[playerid] = INVALID_PLAYER_BAR_ID;

        KillTimer(zTimerLoadscreen[playerid]);
        zTimerLoadscreen[playerid] = 0;

        LoadPercent[playerid] = 0.0;
        LoadStage[playerid] = 0;

        for(new i = 0; i < 11; i++)
        {
            PlayerTextDrawHide(playerid, NexIntro[playerid][i]);
        }

        PlayerTextDrawHide(playerid, NexIntroProg[playerid][0]);

        SetTimerEx("ShowMainMenuCamera", 100, false, "i", playerid);
    }
    return 1;
}

