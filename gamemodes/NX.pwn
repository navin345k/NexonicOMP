		case DIALOG_AWITHDRAW:
	    {
	        if(!response) return 1;
	
	        if(!strlen(inputtext)) return ShowDialogToPlayer(playerid, DIALOG_AWITHDRAW);
	
	        new money = strval(inputtext);
	        if(money < 1 || money > PlayerInfo[playerid][pBank])
            {
				ShowInfo(playerid, "Insufficient amount. Please try again.");
                ShowDialogToPlayer(playerid, DIALOG_AWITHDRAW);
                return 1;
            }
	
	        PlayerInfo[playerid][pBank] -= money;
			GivePlayerCash(playerid, money);
			PlayerInfo[playerid][pLastWithdraw] = money;
			
			new xyzString[128];
		    format(xyzString, sizeof(xyzString), "You have withdrawn $%i from your bank account.", money);
			ShowInfo(playerid, xyzString);
		
			mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET bank = %i WHERE uid = %i", PlayerInfo[playerid][pBank], PlayerInfo[playerid][pID]);
			mysql_tquery(connectionID, queryBuffer);
			
			for(new i = 0; i < 42; i++) 
			{
				TextDrawHideForPlayer(playerid, NexATM[i]);
			}
			for(new i = 0; i < 2; i++)
			{
				PlayerTextDrawHide(playerid, ATMTD[playerid][i]);
			}

			for(new i = 0; i < 78; i++) 
			{
				TextDrawHideForPlayer(playerid, NexBank[i]);
			}
			for(new i = 0; i < 5; i++)
			{
				PlayerTextDrawHide(playerid, BANKTD[playerid][i]);
			}
			CancelSelectTextDraw(playerid);
	
	        ApplyAnimation(playerid, "CRIB", "CRIB_Use_Switch",4.0,0,0,0,0,0), PlayerPlaySound(playerid, 4203, 0,0,0);
	    }
		case DIALOG_ADEPOSIT:
	    {
	        if(!response) return 1;
	
	        if(!strlen(inputtext)) return ShowDialogToPlayer(playerid, DIALOG_ADEPOSIT);
	
	        new money = strval(inputtext);
	        if(!(1 <= money <= 100000000)) return ShowDialogToPlayer(playerid, DIALOG_ADEPOSIT);
	        if(PlayerInfo[playerid][pCash] < money) return ShowDialogToPlayer(playerid, DIALOG_ADEPOSIT);
	
	        PlayerInfo[playerid][pBank] += money;
			GivePlayerCash(playerid, -money);
			PlayerInfo[playerid][pLastDeposit] = money;
			
