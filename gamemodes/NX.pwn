			if(id != -1 && DroppedItems[id][droppedModel])
			{
				//if(GetTotalWeightFloat(playerid) >= 50) return SendClientMessage(playerid, COLOR_WHITE, "Your inventory is full!");
				if(Inventory_Items(playerid) >= MAX_INVENTORY) return SendClientMessage(playerid, COLOR_WHITE, "Your inventory slots are full!");
				
				if(PickupItem(playerid, id))
				{
					SendRPMeAboveHead(playerid, "Picks up something from the ground", X11_PLUM1);
					ApplyAnimation(playerid, "CARRY", "liftup", 3.1, 0, 0, 0, 0, 0, 1);
				}
				//else SendClientMessage(playerid, COLOR_WHITE, "Your inventory is full!");
			}
			else SendClientMessage(playerid, COLOR_WHITE, "That item no longer exists!");
