	if(dialogid == DIALOG_SETAMOUNT)
	{
		if(!response) return SendClientMessage(playerid, COLOR_WHITE, "You have cancelled the selection");

		if(isnull(inputtext))
		{
			ShowPlayerDialog(playerid, DIALOG_SETAMOUNT, DIALOG_STYLE_INPUT, ""BLUE"Nexonic Roleplay "WHITE"- Set Amount",
			"Error: Cannot be left empty!\nPlease enter the number of items to give:", "Set", "Cancel");
			return 1;
		}

		if(!IsNumeric(inputtext))
		{
			ShowPlayerDialog(playerid, DIALOG_SETAMOUNT, DIALOG_STYLE_INPUT, ""BLUE"Nexonic Roleplay "WHITE"- Set Amount",
			"Error: Only numbers are allowed!\nPlease enter the number of items to give:", "Set", "Cancel");
			return 1;
		}

		if(strval(inputtext) < 1)
		{
			ShowPlayerDialog(playerid, DIALOG_SETAMOUNT, DIALOG_STYLE_INPUT, ""BLUE"Nexonic Roleplay "WHITE"- Set Amount",
			"Error: Invalid amount!\nPlease enter the number of items to give:", "Set", "Cancel");
			return 1;
		}

