// ---------------------------------------

// Attach player to local stream as speaker if 'B' key is pressed

public SV_VOID:OnPlayerActivationKeyPress(SV_UINT:playerid, SV_UINT:keyid)
{
    if(keyid != 0x42) return;

    if(PlayerInfo[playerid][pCallStage] == 2 && iconicstream[playerid] != 0)
    {
        SvAttachSpeakerToStream(iconicstream[playerid], playerid);
        return;
    }

    if(PlayerInfo[playerid][pPrRadio] == 1 && IDStream[playerid] >= 1)
    {
        SvAttachSpeakerToStream(StreamFreq[IDStream[playerid]], playerid);
        IsPlayerMicOn[playerid] = 1;
        return;
    }

    if(PlayerInfo[playerid][pFactionRadio] == 1 && factionstream[PlayerInfo[playerid][pFaction]] != 0)
    {
        SvAttachSpeakerToStream(factionstream[PlayerInfo[playerid][pFaction]], playerid);
        return;
    }

    if(PlayerInfo[playerid][pGangRadio] == 1 && gangstream[PlayerInfo[playerid][pGang]] != 0)
    {
        SvAttachSpeakerToStream(gangstream[PlayerInfo[playerid][pGang]], playerid);
        return;
    }

    if(lstream[playerid] != 0)
    {
        SvAttachSpeakerToStream(lstream[playerid], playerid);
    }
}

// Detach the player from the local stream if the 'B' key is released

public SV_VOID:OnPlayerActivationKeyRelease(SV_UINT:playerid, SV_UINT:keyid)
{
    if(keyid != 0x42) return;

    if(PlayerInfo[playerid][pCallStage] == 2 && iconicstream[playerid] != 0)
    {
        SvDetachSpeakerFromStream(iconicstream[playerid], playerid);
        return;
    }

    if(PlayerInfo[playerid][pPrRadio] == 1 && IDStream[playerid] >= 1)
    {
        SvDetachSpeakerFromStream(StreamFreq[IDStream[playerid]], playerid);
        IsPlayerMicOn[playerid] = 0;
        return;
    }

    if(PlayerInfo[playerid][pFactionRadio] == 1 && factionstream[PlayerInfo[playerid][pFaction]] != 0)
    {
        SvDetachSpeakerFromStream(factionstream[PlayerInfo[playerid][pFaction]], playerid);
        return;
    }

    if(PlayerInfo[playerid][pGangRadio] == 1 && gangstream[PlayerInfo[playerid][pGang]] != 0)
    {
        SvDetachSpeakerFromStream(gangstream[PlayerInfo[playerid][pGang]], playerid);
        return;
    }

    if(lstream[playerid] != 0)
    {
        SvDetachSpeakerFromStream(lstream[playerid], playerid);
    }
}

