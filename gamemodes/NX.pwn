forward TurfEndCheck(turfid, check);
public TurfEndCheck(turfid, check)
{
	if(TurfInfo[turfid][tCapturing] == 0)
	{
		KillTimer(TurfTimer[turfid]);
		TurfTimer[turfid] = -1;
		return 1;
	}
	else
	{
		if(check == 1)
		{
			new count = 0;
			foreach(new i : Player)
			{
				if(TurfInfo[turfid][tCapturedGang] == 0)
				{
					if(PlayerInfo[i][pInjured] == 0 && GetNearbyTurf(i) == turfid && PlayerInfo[i][pGang] > 0 && !PlayerInfo[i][pAdminDuty])
					{
						if(PlayerInfo[i][pGang] == TurfInfo[turfid][tAttackingGang] || PlayerInfo[i][pGang] == TurfInfo[turfid][tDefendingGang])
						{
							count++;
						}
					}
				}
				else if(TurfInfo[turfid][tCapturedGang] > 0)
				{
					if(TurfInfo[turfid][tAttackingGang] == 0 || TurfInfo[turfid][tDefendingGang] == 0)
					{
						if(IsLawEnforcement(i) && GetNearbyTurf(i) == turfid && !PlayerInfo[i][pInjured] && !PlayerInfo[i][pAdminDuty])
						{
							count++;
						}
					}
					else
					{
						if(GetNearbyTurf(i) == turfid && PlayerInfo[i][pGang] > 0 && !PlayerInfo[i][pInjured] && !PlayerInfo[i][pAdminDuty])
						{
							if((PlayerInfo[i][pGang] == TurfInfo[turfid][tAttackingGang] || PlayerInfo[i][pGang] == TurfInfo[turfid][tDefendingGang]) && PlayerInfo[i][pGang] != TurfInfo[turfid][tCapturedGang]) 
							{
								count++;
							}
						}
					}
				}
			}
			if(count == 0)
			{
				EndTurf(turfid, 1);
			}
			else
			{
				KillTimer(TurfTimer[turfid]);
				TurfTimer[turfid] = -1;
				return 1;
			}
		}
		else
		{
			EndTurf(turfid, 1);
		}	
	}
	KillTimer(TurfTimer[turfid]);
	TurfTimer[turfid] = -1;
	return 1;
}

forward TeleportPlayerFromTurf(playerid);
public TeleportPlayerFromTurf(playerid)
{
    PlayerInfo[playerid][pInjured] = 0;
    PlayerInfo[playerid][pHunger] = 100;
    PlayerInfo[playerid][pHungerTimer] = 0;
    PlayerInfo[playerid][pThirst] = 100;
    PlayerInfo[playerid][pThirstTimer] = 0;

    SetPlayerPos(playerid, 329.465301, -1803.470581, 4.600659);
    SetCameraBehindPlayer(playerid);
    TogglePlayerControllable(playerid, true);
    SetPlayerHealth(playerid, 100.0);
    SetPlayerVirtualWorld(playerid, 0);
    SetPlayerInterior(playerid, 0);
    ClearAnimations(playerid, true);
    UpdateDynamic3DTextLabelText(InjuredLabel[playerid], COLOR_DOCTOR, "");
    ResetPlayerWeaponsEx(playerid);
	ResetPlayer(playerid);

    SCM(playerid, COLOR_AQUA, "You have been send to Garage From Turf.");
}

