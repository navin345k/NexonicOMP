	mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET ephedrine = %i, muriaticacid = %i, bakingsoda = %i WHERE uid = %i", PlayerInfo[playerid][pEphedrine], PlayerInfo[playerid][pMuriaticAcid], PlayerInfo[playerid][pBakingSoda], PlayerInfo[playerid][pID]);
