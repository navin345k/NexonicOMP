CMD:robcar(playerid, const params[])
{
	new count;

    if(PlayerInfo[playerid][pLevel] < 1)
	{
	    return SCM(playerid, COLOR_ERROR, "You must be at least level 1+ to use this command.");
	}
	if(!IsPlayerInRangeOfPoint(playerid, 5.0, 2637.2646, -2241.4692, 13.5468))
	{
	    return SCM(playerid, COLOR_ERROR, "You are not in range of the Car rob.");
	}
	if(OtherRobberyInfo[rCarTime] > 0)
	{
	    return SCM(playerid, COLOR_ERROR, "The Car can be robbed again in %i minutes. You can't rob it now.", OtherRobberyInfo[rCarTime]);
	}
	if(IsLawEnforcement(playerid))
	{
	    return SCM(playerid, COLOR_ERROR, "You can't rob the Car as a law enforcer.");
	}
	foreach(new i : Player)
	{
	    if(IsLawEnforcement(i) && PlayerInfo[i][pDuty] == 1)
	    {
	        count++;
		}
	}

	if(count < 1)
	{
	    return SCM(playerid, COLOR_GREY2, "There needs to be at least 1+ Police on-duty in order to rob the car.");
	}

	foreach(new i : Player)
	{
		if(IsLawEnforcement(i))
		{
			SM(i, COLOR_RED, "** ALERT: Car Robbery Has Been Started !");
			SetPlayerCheckpoint(i, 2613.0400, -2226.5371, 13.3828, 3.0);
			PlayerPlaySound(playerid, 2200, 0.0, 0.0, 0.0);
		}
	}
    PlayerInfo[playerid][pRob] = 1;
	    
    robcar = CreateVehicle(547, 2619.9377, -2226.7155, 13.1398, 91.39, -1, -1, 0);
    SetPlayerCheckpoint(playerid, -1802.9199, 1312.4536, 59.5055, 5.0);
    SetPVarInt(playerid, "GPS", 1);

    SCM(playerid, COLOR_GREEN, "Robbery vehicle secured. Look behind you and get in,");
    SCM(playerid, COLOR_GREEN, "Police are responding. Stay at the scene!");
    
    OtherRobberyInfo[rCarTime] = 15;
	return 1;
}

CMD:delivercar(playerid, const params[])
{
    new amount = 18000 + random(2001);

	if(!IsPlayerInRangeOfPoint(playerid, 10.0, -1802.9199, 1312.4536, 59.5055))
	{
		return SCM(playerid, COLOR_RED, "You Are Not In Car Robbery Garage");
	}
    if(PlayerInfo[playerid][pRob] == 0) return SCM(playerid, COLOR_RED, "You Haven't Rob Car");
    {
    	PlayerInfo[playerid][pDirtyCash] += amount;
	    PlayerInfo[playerid][pWantedLevel] = 2;
        PlayerInfo[playerid][pRob] -= 1;
        DisablePlayerCheckpoint(playerid);
        DestroyVehicle(robcar);
	    SM(playerid, COLOR_YELLOW, "Car Robbery Success Thief Earned %i Black Money", amount);
	    
	    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET wantedlevel = 2 WHERE uid = %i", PlayerInfo[playerid][pWantedLevel], PlayerInfo[playerid][pID]);
	    mysql_tquery(connectionID, queryBuffer);

        mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET DirtyCash = %i WHERE uid = %i", PlayerInfo[playerid][pDirtyCash], PlayerInfo[playerid][pID]);
	    mysql_tquery(connectionID, queryBuffer);

		mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE inventory SET invQuantity = %i WHERE invItem = 'Dirty Cash' AND uid = %i", PlayerInfo[playerid][pDirtyCash], PlayerInfo[playerid][pID]);
    	mysql_tquery(connectionID, queryBuffer);
	}
	return 1;
}

CMD:robstore(playerid)
{
    new count;

    if(PlayerInfo[playerid][pLevel] < 1)
    {
        return SCM(playerid, COLOR_ERROR, "You must be at least level 1+ to use this command.");
    }
    if(!IsPlayerInRangeOfPoint(playerid, 5.0, 1923.7849, -1785.8378, 13.6228))
    {
        return SCM(playerid, COLOR_ERROR, "You are not in range of the store vault.");
    }
	if(PlayerInfo[playerid][pIsRob] == true)
    {
        return SCM(playerid, COLOR_ERROR, "You are already in the middle of a robbery!");
    }
    if(OtherRobberyInfo[rStoreTime] > 0)
    {
        return SCM(playerid, COLOR_ERROR, "The store can be robbed again in %i minutes. You can't rob it now.", OtherRobberyInfo[rStoreTime]);
    }
    if(IsLawEnforcement(playerid))
    {
        return SCM(playerid, COLOR_ERROR, "You can't rob the store as a law enforcement officer.");
    }

    foreach(new i : Player)
    {
        if(IsLawEnforcement(i) && PlayerInfo[i][pDuty] == 1)
        {
            count++;
        }
    }

    if(count < 2)
    {
        return SCM(playerid, COLOR_GREY2, "There needs to be at least 2+ PD on-duty in order to rob the store.");
    }

    foreach(new i : Player)
    {
        if(IsLawEnforcement(i))
        {
            SM(i, COLOR_RED, "** ALERT: Idlewood Store Robbery Has Been Started !");
            PlayerPlaySound(i, 1058, 0.0, 0.0, 0.0);
            SetPlayerCheckpoint(i, 1914.2434, -1781.2755, 13.5508, 3.0);
        }
    }

	PlayerInfo[playerid][pIsRob] = true;

	OtherRobberyInfo[rStoreTime] = 30;

    ShowProgressBar(playerid, "Triggering...", 30);
    TogglePlayerControllable(playerid, 0);
    
	ApplyAnimation(playerid, "BD_FIRE", "wash_up", 4.0, 1, 0, 0, 0, 0);
	SetTimerEx("StoreRobbery", 30000, false, "i", playerid);
	ApplyActorAnimation(RobberyBot, "SHOP", "SHP_HandsUp_Scr", 4.1, false, false, false, true, 0);
	SetTimerEx("ResetBots", 480000, false, "i", RobberyBot);
    return 1;
}

forward StoreRobbery(playerid);
public StoreRobbery(playerid)
{
	new amount = 30000 + random(5001);
    PlayerInfo[playerid][pDirtyCash] += amount;

	PlayerInfo[playerid][pIsRob] = false;

	SMA(COLOR_WHITE, ""GREEN"Breaking News"WHITE" Idlewood Store Has Been Robbed %d Has Been Stolen.", amount);
    TogglePlayerControllable(playerid, 1);

    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET dirtycash = %i WHERE uid = %i", PlayerInfo[playerid][pDirtyCash], PlayerInfo[playerid][pID]);
    mysql_tquery(connectionID, queryBuffer);
    
    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE inventory SET invQuantity = %i WHERE invItem = 'Dirty Cash' AND uid = %i", PlayerInfo[playerid][pDirtyCash], PlayerInfo[playerid][pID]);
    mysql_tquery(connectionID, queryBuffer);
}

CMD:robhouse(playerid, const params[])
{
	new houseid = GetInsideHouse(playerid), count;
	if(gRobbery)
	{
	    return SCM(playerid, COLOR_GREY2, "There is still an active robbery or the admin disabled the robbery of house/biz.");
	}
	if(houseid == -1)
	{
	    return SCM(playerid, COLOR_GREY2, "You aren't inside a house that you can rob.");
	}
	if(IsHouseOwner(playerid, houseid)) {
		return SCM(playerid, COLOR_GREY2, "You can't rob the your house.");
	}
	if(PlayerInfo[playerid][pLevel] < 2)
	{
	    return SCM(playerid, COLOR_GREY2, "You need to be level 2+ in order to rob a house.");
	}
	if(PlayerInfo[playerid][pRobbingHouse] >= 0)
	{
		return SCM(playerid, COLOR_GREY2, "You're already robbing a house.");
	}
	if(HouseInfo[houseid][hRobbing] == 1)
	{
	    return SCM(playerid, COLOR_GREY2, "You can't rob the house. Robbery has already started.");
	}
	if(HouseInfo[houseid][hRobbed] > 0)
	{
	    return SM(playerid, COLOR_GREY2, "This house can be robbed again in %i hours. You can't rob it now.", HouseInfo[houseid][hRobbed]);
	}
	if(PlayerInfo[playerid][pDuty] == 1)
	{
	    return SCM(playerid, COLOR_GREY2, "You can't rob the house while on-duty.");
	}

	foreach(new i : Player)
	{
	    if(IsLawEnforcement(i) && PlayerInfo[i][pDuty] == 1)
	    {
	        count++;
		}
	}

	if(count < 3)
	{
	    return SCM(playerid, COLOR_GREY2, "There needs to be at least 3+ LEO on-duty in order to rob the house.");
	}

	foreach(new i : Player)
	{
		if(IsLawEnforcement(i))
		{
			SM(i, COLOR_ROYALBLUE, "** HQ: A robbery is occurring at the %s. All units respond immediately.", GetZoneName(HouseInfo[houseid][hPosX],HouseInfo[houseid][hPosY],HouseInfo[houseid][hPosZ]));
			SetPlayerCheckpoint(i, HouseInfo[houseid][hPosX],HouseInfo[houseid][hPosY],HouseInfo[houseid][hPosZ], 3.0);
		}
	}

	PlayerInfo[playerid][pLootTime] = 5;
	GameTextForPlayer(playerid, "~w~Looting house vault...", 5000, 3);
	
	gRobbery = true;
	SMA(COLOR_YELLOW, "Breaking News"WHITE":"RED"%s"YELLOW" has attempted to rob a "GREEN"HOUSE"YELLOW", COPS MUST RESPOND!!", GetRPName(playerid));

	// new string[128];
	// format(string, sizeof(string), "~r~House Robbery");
    // TextDrawSetString(PriorityTD[1], string);

 	SendProximityMessage(playerid, 20.0, COLOR_PURPLE, "* %s attempts to rob the house.", GetRPName(playerid));
	SCM(playerid, COLOR_GREY2,"** Wait until cops arrive for roleplay purposes. (( You can door shout by inputting '/ds'. ))");
	PlayerInfo[playerid][pRobbingHouse] = houseid;
	HouseInfo[houseid][hRobbing] = 1;
	return 1;
}

