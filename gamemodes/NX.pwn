	}
	if(textid == NexRadio[playerid][21]) // leave
	{
	    callcmd::leaveradio(playerid, "/1");
	}

	// NexLogin
	if(textid == NexLogin[playerid][19]) // Password
	{
		new titlestring[64], string[128];
		format(titlestring, sizeof(titlestring), "{3399FF}Nexonic Login");
		format(string, sizeof(string), "{FFFFFF}Welcome to Nexonic Roleplay, %s.\n\nThe name that you are using is registered, please enter a password to login:", GetPlayerNameEx(playerid));
		ShowPlayerDialog(playerid, DIALOG_PASSWORD, DIALOG_STYLE_PASSWORD, titlestring, string, "Enter", "Exit");
	}
	if(textid == NexLogin[playerid][20]) // Login
	{
		new specifiers[] = "%D of %M, %Y @ %k:%i", password[129];
		GetPVarString(playerid, "TypingPassword", password, sizeof(password));
		WP_Hash(password, sizeof(password), password);
		mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "SELECT *, DATE_FORMAT(lastlogin, '%s') AS login_date FROM users WHERE username = '%s' AND password = '%s'", specifiers, GetPlayerNameEx(playerid), password);
		mysql_tquery(connectionID, queryBuffer, "OnQueryFinished", "ii", THREAD_PROCESS_LOGIN, playerid);
		PlayerInfo[playerid][pLoggingIn] = 0;
	}
	for(new i = 0; i < 20; i++)
	{
