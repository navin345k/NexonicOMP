		    PlayerTextDrawHide(playerid, NexRadio[playerid][i]);
		}
		CancelSelectTextDraw(playerid);
	}
	if(textid == NexRadio[playerid][47]) // clear
	{
	    PlayerTextDrawSetString(playerid, NexRadio[playerid][50], "");
