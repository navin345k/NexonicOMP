								PlayerInfo[playerid][pVest] = 5;
					            SendProximityMessage(playerid, 20.0, SERVER_COLOR, "**{C2A2DA} %s grabs vest from the locker.", GetRPName(playerid));

								mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET vest = %i WHERE uid = %i", PlayerInfo[playerid][pVest], PlayerInfo[playerid][pID]);
					            mysql_tquery(connectionID, queryBuffer);
					        }
					        case 1:
					        {
					            GiveWeapon(playerid, 23);
					            SendProximityMessage(playerid, 20.0, SERVER_COLOR, "**{C2A2DA} %s grabs an silenced pistol from the locker.", GetRPName(playerid));
					        }
					        case 2:
