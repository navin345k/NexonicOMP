		case DialogDropItem:
		{
			if(!response) return SendClientMessage(playerid, COLOR_WHITE, "You have cancelled the selection");
			new 
				itemid = PlayerInfo[playerid][pSelectItem],
				str[32],
				string[256];

			strunpack(string, InventoryData[playerid][itemid][invItem]);

			if(response)
			{
				if(isnull(inputtext))
					return format(str, sizeof str, "Item: %s - Amount: %dx\n\nPlease enter the amount you want to drop:", string, InventoryData[playerid][itemid][invQuantity]);
				ShowPlayerDialog(playerid, DialogDropItem, DIALOG_STYLE_INPUT, ""BLUE"Nexonic Roleplay "WHITE"- Drop Item", str, "Drop", "Cancel");

				if(strval(inputtext) < 1 || strval(inputtext) > InventoryData[playerid][itemid][invQuantity])
					return format(str, sizeof str, "ERROR: You don‚Äôt have that many items\n\nItem: %s - Amount: %dx\n\nPlease enter the amount you want to drop:", string, InventoryData[playerid][itemid][invQuantity]);
				ShowPlayerDialog(playerid, DialogDropItem, DIALOG_STYLE_INPUT, ""BLUE"Nexonic Roleplay "WHITE"- Drop Item", str, "Drop", "Cancel");

				DropPlayerItem(playerid, itemid, strval(inputtext));
			}
		}
