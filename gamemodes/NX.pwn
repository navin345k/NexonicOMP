forward OnAdminChangePassword(playerid, username[], password[]);
public OnAdminChangePassword(playerid, username[], password[])
{
	if(!cache_get_row_count(connectionID))
	{
	    SendClientMessage(playerid, COLOR_GREY, "The player specified doesn't exist.");
	}
	else
	{
	    new
	        hashed[129];

	    WP_Hash(hashed, sizeof(hashed), password);

	    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET password = '%s' WHERE username = '%e'", hashed, username);
	    mysql_tquery(connectionID, queryBuffer);

	    SendAdminMessage(COLOR_LIGHTRED, "AdmCmd: %s has changed %s's account password.", GetRPName(playerid), username);
	}
}

forward OnVerifyRemoveFlag(playerid, targetid, slot);
public OnVerifyRemoveFlag(playerid, targetid, slot)
{
	if(cache_get_row_count(connectionID))
	{
	    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "DELETE FROM flags WHERE id = %i", cache_get_row_int(0, 0));
	    mysql_tquery(connectionID, queryBuffer);

	    SM(playerid, COLOR_YELLOW, "** %s's flag in slot %i was removed.", GetRPName(targetid), slot);
	}
	else
	{
	    SCM(playerid, COLOR_SYNTAX, "That player has no outstanding flag in that slot.");
	}
}

forward OnVerifyRentVehicle();
public OnVerifyRentVehicle()
{
	new rows = cache_get_row_count(connectionID);
	if(rows)
	{
	    for(new i = 0; i < rows; i ++)
	    {
		    new vehicleid = GetVehicleLinkedID(cache_get_field_content_int(i, "id")), renttime = cache_get_field_content_int(i, "renttime"), modelid = cache_get_field_content_int(0, "modelid");
		    new ownername[MAX_PLAYER_NAME];
		    cache_get_field_content(i, "owner", ownername, connectionID, MAX_PLAYER_NAME);
			if(renttime == 0)
			{
			    foreach(new j : Player)
			    {
			        if(!strcmp(GetPlayerNameEx(j), ownername) && PlayerInfo[j][pLogged])
			        {
			            PlayerInfo[j][pRented] -= 1;
			            SM(j, COLOR_AQUA, "Your Vehicle {FF6347}%s{33CCFF} rent has been Expired.", vehicleNames[modelid - 400]);
			        }
			    }
			    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET rented = rented - 1 WHERE uid = %i", cache_get_field_content_int(i, "ownerid"));
			    mysql_tquery(connectionID, queryBuffer);
			    mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "DELETE FROM vehicles WHERE id = %i", cache_get_field_content_int(i, "id"));
			    mysql_tquery(connectionID, queryBuffer);

			    if(vehicleid != INVALID_VEHICLE_ID)
			    {
			        DespawnVehicle(vehicleid, false);
				}
			}
			else
			{
				renttime--;
				mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE vehicles SET renttime = %i WHERE id = %i",renttime, cache_get_field_content_int(i, "id"));
			    mysql_tquery(connectionID, queryBuffer);
			}
		}
	}
}

forward OnUnRentVehicleList(playerid);
public OnUnRentVehicleList(playerid)
{
    new rows = cache_get_row_count(connectionID);

    if(rows)
    {
		static string[1024];

		string = "Model\tLocation\tRent Time";

		for(new i = 0; i < rows; i ++)
    	{
			new
				vehicleid = GetVehicleLinkedID(cache_get_field_content_int(i, "id"));

			if(vehicleid == INVALID_VEHICLE_ID)
			{
				format(string, sizeof(string), "%s\n%s\t%s\t%i", string, vehicleNames[cache_get_field_content_int(i, "modelid") - 400], (cache_get_field_content_int(i, "interior")) ? ("Garage") : GetZoneName(cache_get_field_content_float(i, "pos_x"), cache_get_field_content_float(i, "pos_y"), cache_get_field_content_float(i, "pos_z")),cache_get_field_content_int(i, "renttime"));
			}
			else
			{
				format(string, sizeof(string), "%s\n%s\t%s\t%i", string, GetVehicleName(vehicleid), GetVehicleZoneName(vehicleid),cache_get_field_content_int(i, "renttime"));
			}
		}
		ShowPlayerDialog(playerid, DIALOG_REMOVERC, DIALOG_STYLE_TABLIST_HEADERS, "Choose a vehicle to Unrent.", string, "Unrent", "Cancel");
	}
}

forward OnUnRentVehicle(playerid);
public OnUnRentVehicle(playerid)
{
    new rows = cache_get_row_count(connectionID);
    if(rows)
    {
        new dbID = cache_get_field_content_int(0, "id");
        new modelid = cache_get_field_content_int(0, "modelid");
        new vehicleid = GetVehicleLinkedID(dbID);

        mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "DELETE FROM vehicles WHERE id = %i", dbID);
        mysql_tquery(connectionID, queryBuffer);

        if(vehicleid != INVALID_VEHICLE_ID)
        {
            DespawnVehicle(vehicleid, false);
        }

        if(PlayerInfo[playerid][pRented] > 0) PlayerInfo[playerid][pRented] -= 1;

        mysql_format(connectionID, queryBuffer, sizeof(queryBuffer), "UPDATE users SET rented = %i WHERE uid = %i", PlayerInfo[playerid][pRented], PlayerInfo[playerid][pID]);
        mysql_tquery(connectionID, queryBuffer);

        SM(playerid, COLOR_AQUA, "You have successfully unrented your {FF6347}%s{33CCFF}.", vehicleNames[modelid - 400]);
    }
    else
    {
        SCM(playerid, COLOR_GREY, "You don't have any rented vehicles to cancel.");
    }
    return 1;
}

forward OnAdminCreatePG(playerid, atm, Float:x, Float:y, Float:z, Float:a);
public OnAdminCreatePG(playerid, atm, Float:x, Float:y, Float:z, Float:a)
{
    PGInfo[atm][aID] = cache_insert_id(connectionID);
	PGInfo[atm][aExists] = true;
    PGInfo[atm][aPosX] = x;
    PGInfo[atm][aPosY] = y;
    PGInfo[atm][aPosZ] = z;
    PGInfo[atm][aPosA] = a;

	ReloadPG(atm);
	SM(playerid, COLOR_TEAL, "** Public Garage "WHITE"[%i]"TEAL" created at %.1f, %.1f, %.1f.", atm, x, y, z);
}

forward OnAdminCreateDynamicActor(playerid, id, skin, world, Float:x, Float:y, Float:z, Float:a);
public OnAdminCreateDynamicActor(playerid, id, skin, world, Float:x, Float:y, Float:z, Float:a)
{
    ActorInfo[id][acID] = cache_insert_id(connectionID);
    ActorInfo[id][acExists] = 1;

    ActorInfo[id][acPosX] = x;
    ActorInfo[id][acPosY] = y;
    ActorInfo[id][acPosZ] = z;
    ActorInfo[id][acPosA] = a;

    ActorInfo[id][acSkin] = skin;
    ActorInfo[id][acWorld] = world;

    ReloadActors(id);

    new string[144];
    format(string, sizeof(string), "AdmCmd: %s %s has created Actor at %s.", GetStaffRank(playerid), GetRPName(playerid), GetZoneName(x, y, z));
    SAM(COLOR_LIGHTRED, string);

    format(string, sizeof(string), "** Actor [%d] created at %.1f, %.1f, %.1f.", id, x, y, z);
    SCM(playerid, COLOR_GREEN, string);

    return 1;
}
