public OnPlayerDisconnect(playerid, reason)
{
    if(lstream[playerid])
    {
        SvDeleteStream(lstream[playerid]);
        lstream[playerid] = SV_NULL;
    }
	TerminateInfo(playerid, reason);
    
    if(IsValidActor(PlayerInfo[playerid][pEmsActor]))
	{
		DestroyActor(PlayerInfo[playerid][pEmsActor]);
	}
		
	if(IsValidActor(PlayerInfo[playerid][pMechActor]))
	{
		DestroyActor(PlayerInfo[playerid][pMechActor]);
	}

	if(IsShipMember(playerid))
    {
        TransferKeys(playerid);
        RemoveShipMember(playerid);

        if(ShipActive && ShipMemberCount == 0)
        {
            SendClientMessageToAll(-1, "Ship Robbery Failed!");
            ResetShip();
        }
    }

	new channel = RadioChannel[playerid];
    RadioChannel[playerid] = INVALID_CHANNEL;
    IsPlayerMicOn[playerid] = 0;

    if (ChannelText[playerid] != Text:INVALID_TEXT_DRAW)
    {
        TextDrawDestroy(ChannelText[playerid]);
        ChannelText[playerid] = Text:INVALID_TEXT_DRAW;
    }
	UpdateRadioDisplayForAll(channel);

	new string[256];
	new name[MAX_PLAYER_NAME];
	format(name, sizeof(name), "%s", GetRPName(playerid));

	new DCC_Embed:embed = DCC_CreateEmbed();
	DCC_SetEmbedTitle(embed, "Player Disconnected");
	format(string, sizeof(string), "%s has left Nexonic Roleplay.", name);
	DCC_SetEmbedDescription(embed, string);
	DCC_SetEmbedColor(embed, 0xFF0000);
	DCC_SetEmbedThumbnail(embed, "https://i.postimg.cc/sxfVT479/logo.png");
	DCC_AddEmbedField(embed, "Player Name", name, true);
	DCC_SetEmbedFooter(embed, "Nexonic Roleplay", "");
	DCC_SendChannelEmbedMessage(logoutlogs, embed);

	UpdateBotStatus();

	for(new i = 0; i < MAX_PLAYERS; i++)
    {
        if(IsPlayerConnected(i) && PlayerInfo[i][pLocationRequest] == playerid)
        {
            PlayerInfo[i][pLocationRequest] = INVALID_PLAYER_ID;
        }
    }

	PlayerInfo[playerid][pGangRadio] = 0;
    PlayerInfo[playerid][pFactionRadio] = 0;

	return 1;
}

public OnPlayerRequestClass(playerid, classid)
{
    if(PlayerInfo[playerid][pKicked]) return 0;
    if(IsPlayerNPC(playerid)) return 1;

	if(!PlayerInfo[playerid][pLogged])
	{
		PlayAudioStreamForPlayer(playerid, "https://c.top4top.io/m_37375965o1.mp3");

	    ClearChat(playerid);
    	for(new i = 0; i < 5; i ++)
		{
		    SCM(playerid, -1, " ");
		}
		TogglePlayerSpectating(playerid, 1);
		SetPlayerColor(playerid, 0xFFFFFF00);

		// Due to a SA-MP bug, you can't apply camera coordinates directly after enabling spectator mode (to hide HUD).
		// In this case we'll use a timer to defer this action.

		// SendClientMessage(playerid, 0x818689FF, "[LOGIN] Loading data, please wait a few seconds...");

		// SetTimerEx("ShowMainMenuCamera", 100, false, "i", playerid);
		
	    SetTimerEx("ProgressLoader", 500, false, "i", playerid);

        switch(random(2))
        {
            case 0:
            {
				InterpolateCameraPos(playerid, 1358.270263, -1400.463378, 16.012187, 635.142089, -1397.839477, 16.242132, 25000);
				InterpolateCameraLookAt(playerid, 1358.198120, -1395.467773, 15.816926, 630.169982, -1398.341796, 16.402261, 25000);
            }
            case 1:
            {
				InterpolateCameraPos(playerid, 1152.572387, -1576.658813, 126.939743, 2037.290283, -1873.286132, 75.740158, 20000);
				InterpolateCameraLookAt(playerid, 1157.089477, -1577.831176, 125.144783, 2040.672485, -1870.160522, 73.793060, 20000);
            }
		}
	}

	return 1;
}

public OnPlayerSpawn(playerid)
{

	// FPS - Display
	TextDrawShowForPlayer(playerid, FPSDisplayTD[0]);
	TextDrawShowForPlayer(playerid, FPSDisplayTD[1]);
	TextDrawShowForPlayer(playerid, FPSDisplayTD[2]);
	TextDrawShowForPlayer(playerid, FPSDisplayTD[3]);
	TextDrawShowForPlayer(playerid, FPSDisplayTD[4]);
	TextDrawShowForPlayer(playerid, FPSDisplayTD[5]);

	PlayerTextDrawShow(playerid, FPSDisplay[playerid][0]);
	PlayerTextDrawShow(playerid, FPSDisplay[playerid][1]);
	PlayerTextDrawShow(playerid, FPSDisplay[playerid][2]);
	PlayerTextDrawShow(playerid, FPSDisplay[playerid][3]);
	PlayerTextDrawShow(playerid, FPSDisplay[playerid][4]);

	FpsDisplayUpdate[playerid] = SetTimerEx("FpsDisplayGame", 3000, true, "d", playerid);

    if(PlayerInfo[playerid][pKicked]) return 0;
	PreloadAnims(playerid);

	if(PlayerInfo[playerid][pSetup])
	{
	    if(PlayerInfo[playerid][pTutorial])
	    {
	        KillTimer(PlayerInfo[playerid][pTutorialTimer]);
	        PlayerInfo[playerid][pTutorial] = 0;
	    }

	    TogglePlayerControllable(playerid, false);
	    TogglePlayerSpectating(playerid, false);

	    InsideTut[playerid] = 1;

	    SetPlayerVirtualWorld(playerid, playerid);

	    SetPlayerPos(playerid, 2094.4937, -1641.5861, 1258.0033);
	    SetPlayerFacingAngle(playerid, 265.7285);
	    InterpolateCameraPos(playerid, 2100.234375, -1641.625000, 1258.306396, 2100.234375, -1641.625000, 1258.306396, 5000);
	    InterpolateCameraLookAt(playerid, 2095.237304, -1641.616333, 1258.480590, 2095.237304, -1641.616333, 1258.480590, 5000);
	    SelectTextDraw(playerid, COLOR_RED);
	    StopAudioStreamForPlayer(playerid);

	    for(new i; i < 33; i++)
	    {
	        PlayerTextDrawHide(playerid, NexHUD[playerid][i]);
	    }

	    for(new i; i < 2; i++)
	    {
	        PlayerTextDrawHide(playerid, PlayerID[playerid][i]);
	    }

	    ResetCharacterSetup(playerid);

	    for(new i; i < 37; i++)
	    {
	        PlayerTextDrawShow(playerid, CharacterUI[playerid][i]);
	    }

	    ClearChat(playerid);
	}
	else if(PlayerInfo[playerid][pJailTime] > 0)
	{
	    SetPlayerInJail(playerid);
	    if(PlayerInfo[playerid][pJailType] == 2)
	    {
	        SM(playerid, COLOR_LIGHTRED, "** You were placed in admin prison by %s, reason: %s", PlayerInfo[playerid][pPrisonedBy], PlayerInfo[playerid][pPrisonReason]);
		}
		else
		{
			SCM(playerid, COLOR_LIGHTRED, "** You haven't completed your jail sentence yet.");
		}
	}
	else if(PlayerInfo[playerid][pPaintball] > 0)
	{
	    SetPlayerInPaintball(playerid, PlayerInfo[playerid][pPaintball]);
	}
	else
	{
	    PlayerInfo[playerid][pJoinedEvent] = 0;

	    if(PlayerInfo[playerid][pInjured])
	    {
	        SetPlayerHealth(playerid, 100.0);
	        SetPlayerArmour(playerid, 0.0);
            ApplyAnimation(playerid, "SWEET", "Sweet_injuredloop", 4.1, 0, 0, 0, 1, 0, 1);

			for(new i = 0; i < 18; i++) 
			{
				PlayerTextDrawShow(playerid, InjuredTD[playerid][i]);
			}

	        SCM(playerid, COLOR_DOCTOR, "[!] >> You are badly injured.You can wait for and ambulance by entering '/call 911'");
	        SCM(playerid, COLOR_DOCTOR, "You have been Brutally Wounded, Now if a medic or somebody doesn't help you. you will die.");

			new string[128];
			format(string, sizeof(string), "(( Has been wounded ))");
			UpdateDynamic3DTextLabelText(InjuredLabel[playerid], COLOR_DOCTOR, string);

			TogglePlayerControllable(playerid, false);
			SetTimerEx("UnfreezePlayerEx", 5000, false, "i", playerid);

            if(PlayerInfo[playerid][pTagType] == TAG_MASK)
			{
			 	SetPlayerSpecialTag(playerid, TAG_NORMAL);
			}
		   	Maskara[playerid] = 0;
		   	MaskaraID[playerid] = 0;
	        PlayerInfo[playerid][pDeathCooldown] = 300;
	    }
	    else if(PlayerInfo[playerid][pHospital])
	    {
	        if(PlayerInfo[playerid][pInsurance] == 0)
     	   		SetPlayerInHospital(playerid);
	        else
				SetPlayerInHospital(playerid, .type = PlayerInfo[playerid][pInsurance]);

			ResetPlayerWeaponsEx(playerid);
	    }
	    else
		{
		    SetPlayerHealth(playerid, PlayerInfo[playerid][pHealth]);
		    SetScriptArmour(playerid, PlayerInfo[playerid][pArmor]);
		}

		if(!PlayerInfo[playerid][pHospital])
		{
		    if(PlayerInfo[playerid][pDueling] != INVALID_PLAYER_ID)
			{
				PlayerInfo[PlayerInfo[playerid][pDueling]][pDueling] = INVALID_PLAYER_ID;
				PlayerInfo[playerid][pDueling] = INVALID_PLAYER_ID;
			}

			SetPlayerPos(playerid, PlayerInfo[playerid][pPosX], PlayerInfo[playerid][pPosY], PlayerInfo[playerid][pPosZ]);
			SetPlayerFacingAngle(playerid, PlayerInfo[playerid][pPosA]);
			SetPlayerInterior(playerid, PlayerInfo[playerid][pInterior]);
	 		SetPlayerVirtualWorld(playerid, PlayerInfo[playerid][pWorld]);
			SetPlayerWeapons(playerid);
		}
	}
	SetPlayerSkin(playerid, PlayerInfo[playerid][pSkin]);
	SetPlayerFightingStyle(playerid, PlayerInfo[playerid][pFightStyle]);
	SetPlayerSkillLevel(playerid, WEAPONSKILL_MICRO_UZI, 998);
	SetPlayerSkillLevel(playerid, WEAPONSKILL_PISTOL, 998);
 	SetPlayerSkillLevel(playerid, WEAPONSKILL_SAWNOFF_SHOTGUN, 998);
	SetPlayerClothing(playerid);

    // NexLogo
    for(new i = 0; i < 4; i++)
    {
		TextDrawShowForPlayer(playerid, NexLogo[i]);
	}

	return 1;
}

UpdateCharacterSetup(playerid)
{
	new string[64], gender[8];
	if(PlayerInfo[playerid][pGender] == 1) gender = "Male";
	else if(PlayerInfo[playerid][pGender] == 2) gender = "Female";
	else if(PlayerInfo[playerid][pGender] == 3) gender = "Shemale";

	format(string, sizeof(string), "Name: %s", GetRPName(playerid));
	PlayerTextDrawSetString(playerid, CharacterUI[playerid][2], string);

	format(string, sizeof(string), "Gender: %s", gender);
	PlayerTextDrawSetString(playerid, CharacterUI[playerid][3], string);

	format(string, sizeof(string), "Skin: %i", PlayerInfo[playerid][pOutfit]);
	PlayerTextDrawSetString(playerid, CharacterUI[playerid][4], string);

	format(string, sizeof(string), "Age: %i", PlayerInfo[playerid][pAge]);
	PlayerTextDrawSetString(playerid, CharacterUI[playerid][5], string);
}

ResetCharacterSetup(playerid)
{
    if (PlayerInfo[playerid][pSetup])
    {
        PlayerInfo[playerid][pSkin] = g_MaleSkins[0];
        PlayerInfo[playerid][pAge] = 13;
        PlayerInfo[playerid][pGender] = GENDER_MALE;
        PlayerInfo[playerid][pOutfit] = 0;

        SetPlayerSkin(playerid, PlayerInfo[playerid][pSkin]);
        UpdateCharacterSetup(playerid);
    }
}

UpdateSkinSelection(playerid, index)
{
	new size;

	if (PlayerInfo[playerid][pGender] == GENDER_MALE)
	{
		size = sizeof(g_MaleSkins);
	}
	else if (PlayerInfo[playerid][pGender] == GENDER_FEMALE)
	{
		size = sizeof(g_FemaleSkins);
	}

	if (index < 0)
	{
		index = size-1;
	}
	else if (index >= size) 
	{
		index = 0;
	}

	PlayerInfo[playerid][pOutfit] = index;

	if (PlayerInfo[playerid][pGender] == GENDER_MALE) 
	{
		PlayerInfo[playerid][pSkin] = g_MaleSkins[index];
	}
	else if (PlayerInfo[playerid][pGender] == GENDER_FEMALE) 
	{
		PlayerInfo[playerid][pSkin] = g_FemaleSkins[index];
	}

	SetPlayerSkin(playerid, PlayerInfo[playerid][pSkin]);
}

