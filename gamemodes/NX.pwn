CMD:crushcrack(playerid, const params[])
{
	if(gettime() - PlayerInfo[playerid][pProc1] < 21)
	{
	    return SM(playerid, COLOR_GREY, "You can only use job command in every 21 sec. Please wait %i more seconds.", 21 - (gettime() - PlayerInfo[playerid][pProc1]));
	}
	if(PlayerInfo[playerid][pGang] == -1)
	{
		return SM(playerid, COLOR_GREY, "You can't use this command as you're not a gang member.");
	}
	if(!IsPlayerInRangeOfPoint(playerid, 5.0, -182.566543, -784.452941, 3474.271728) && !IsPlayerInRangeOfPoint(playerid, 5.0, -182.566665, -788.290039, 3474.271728) && !IsPlayerInRangeOfPoint(playerid, 5.0, -182.566040, -786.190063, 3474.271728) && !IsPlayerInRangeOfPoint(playerid, 5.0, -182.566528, -782.249206, 3474.271728))
	{
	    return SM(playerid, COLOR_GREY, "You are not inside of the crack grinding turf.");
	}
	if(PlayerInfo[playerid][pMixedcrack] <= 2)
	{
	     return SendClientMessage(playerid, COLOR_ERROR, "You don't have enough packet of mixtures.");
	 }
	if(PlayerInfo[playerid][pCrushedcrack] >= 5)
	{
	     return SendClientMessage(playerid, COLOR_ERROR, "You can't hold more than 4 packets of cushed crack.");
	 }
	
	PlayerInfo[playerid][pProc1] = gettime();
	
	ShowProgressBar(playerid, "Crushing Crack", 20);
	ApplyAnimationEx(playerid, "BD_FIRE", "wash_up", 4.0, 1, 1, 1, 0, 0);
	SetTimerEx("Crush", 20000, false, "i", playerid);
	PlayerPlaySound(playerid, 1133, 0.0, 0.0, 0.0);
	return 1;
}

CMD:packcrack(playerid, const params[])
{
	if(gettime() - PlayerInfo[playerid][pProc1] < 11)
	{
	    return SM(playerid, COLOR_GREY, "You can only use job command in every 11 sec. Please wait %i more seconds.", 11 - (gettime() - PlayerInfo[playerid][pProc1]));
	}
	if(PlayerInfo[playerid][pGang] == -1)
	{
		return SM(playerid, COLOR_GREY, "You can't use this command as you're not a gang member.");
	}
	if(!IsPlayerInRangeOfPoint(playerid, 5.0, -179.616149, -777.127502, 3474.529052) && !IsPlayerInRangeOfPoint(playerid, 5.0, -179.617019, -771.611083, 3474.529052) && !IsPlayerInRangeOfPoint(playerid, 5.0, -281.521606, -772.729858, 3474.728759))
	{
	    return SM(playerid, COLOR_GREY, "You are not inside of the crack grinding turf.");
	}
	if(PlayerInfo[playerid][pCrushedcrack] <= 1)
	{
	     return SendClientMessage(playerid, COLOR_ERROR, "You don't any packets of crushed crack left");
	 }
	if(PlayerInfo[playerid][pCrack] > GetPlayerCapacity(playerid, CAPACITY_COCAINE))
	{
	    return SM(playerid, COLOR_SYNTAX, "You currently have %i/%i crack.", PlayerInfo[playerid][pCrack], GetPlayerCapacity(playerid, CAPACITY_COCAINE));
	}
	
	PlayerInfo[playerid][pProc1] = gettime();
	ShowProgressBar(playerid, "Packing Crack", 10);
	ApplyAnimationEx(playerid, "BD_FIRE", "wash_up", 4.0, 1, 1, 1, 0, 0);
	SetTimerEx("Packcrack", 10000, false, "i", playerid);
	SM(playerid, COLOR_GREY, "You have started Pack the crushed crack. It will be ready in 10 seconds");
	PlayerPlaySound(playerid, 1133, 0.0, 0.0, 0.0);
	
	return 1;
}

CMD:meltmat(playerid, const params[])
{
	if(gettime() - PlayerInfo[playerid][pProc1] < 16)
	{
