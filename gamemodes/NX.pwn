}

CMD:ccp(playerid, const params[]) return callcmd::cancelcp(playerid, params);
CMD:kcp(playerid, const params[]) return callcmd::cancelcp(playerid, params);
CMD:killcp(playerid, const params[]) return callcmd::cancelcp(playerid, params);
CMD:killcheckpoint(playerid, const params[]) return callcmd::cancelcp(playerid, params);
CMD:cancelcp(playerid, const params[])
{
	CancelActiveCheckpoint(playerid);
	PlayerInfo[playerid][pRobCash] = 0;
	SCM(playerid, COLOR_WHITE, "You have cancelled all active checkpoints.");
