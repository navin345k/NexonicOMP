	if(!IsPlayerInRangeOfPoint(playerid, 10.0, -3.363192, -787.476989, 3474.271728) || !IsPlayerInRangeOfPoint(playerid, 10.0, -3.587840, -784.509521, 3474.271728) || !IsPlayerInRangeOfPoint(playerid, 10.0, -3.431404, -781.881225, 3474.271728))
	{
	    return SM(playerid, COLOR_GREY, "You are not inside of the material grinding turf.");
