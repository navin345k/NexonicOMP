forward CreateVine();
forward SwitchColours();

public OnFilterScriptInit()
{   
    CreateVine();
    
    foreach(new i : Player)
    {
        RemoveVine(i);
    }
    
    return 1;
}

public OnFilterScriptExit()
{
    for(new i = 0; i < sizeof(gDynamicObjects); i++)
    {
        if(IsValidDynamicObject(gDynamicObjects[i]))
        {
            DestroyDynamicObject(gDynamicObjects[i]);
            gDynamicObjects[i] = INVALID_STREAMER_ID;
        }
    }
    return 1;
}

public OnPlayerConnect(playerid)
{
    RemoveVine(playerid);
    return 1;
}

public CreateVine()
{
    new index = 0;
    
    for (new i = 0; i < sizeof(APositions); i++)
    {
        gDynamicObjects[index++] = CreateDynamicObject(2972, 
            APositions[i][0], APositions[i][1], APositions[i][2], 
            APositions[i][3], APositions[i][4], APositions[i][5],
            -1, -1, -1, 300.0, 300.0
        );
    }
    
    for (new i = 0; i < sizeof(BPositions); i++)
    {
        gDynamicObjects[index++] = CreateDynamicObject(2972, 
            BPositions[i][0], BPositions[i][1], BPositions[i][2], 
            BPositions[i][3], BPositions[i][4], BPositions[i][5],
            -1, -1, -1, 300.0, 300.0
        );
    }
    
    SetTimer("SwitchColours", 5000, true);
    return 1;
}

public SwitchColours()
{
    static const colors[2][2] = {
        {18996, 7650},
        {7650, 18996}
    };
    
    static const textures[2][2][] = {
        {"mattextures", "vgnusedcar"}, 
        {"vgnusedcar", "mattextures"} 
    };
    
    static const colorNames[2][2][] = {
        {"sampwhite", "lightpurple2_32"}, 
        {"lightpurple2_32", "sampwhite"}
    };

    new index = 0;
    
    for (new i = 0; i < sizeof(APositions); i++)
    {
        if (IsValidDynamicObject(gDynamicObjects[index]))
        {
            SetDynamicObjectMaterial(gDynamicObjects[index], 0, colors[gColorState][0], textures[gColorState][0], colorNames[gColorState][0], 0x00000000);
            SetDynamicObjectMaterial(gDynamicObjects[index], 1, 10765, "airportgnd_sfse", "black64", 0x00000000);
        }
        index++;
    }

    for (new i = 0; i < sizeof(BPositions); i++)
    {
        if (IsValidDynamicObject(gDynamicObjects[index]))
        {
            SetDynamicObjectMaterial(gDynamicObjects[index], 0, colors[gColorState][1], textures[gColorState][1], colorNames[gColorState][1], 0x00000000);
            SetDynamicObjectMaterial(gDynamicObjects[index], 1, 10765, "airportgnd_sfse", "black64", 0x00000000);
        }
        index++;
    }

    gColorState = (gColorState == 0) ? 1 : 0; 
    return 1;
}

RemoveVine(playerid)
{   
    RemoveBuildingForPlayer(playerid, 13722, 1413.410, -804.742, 83.436, 0.250);
    RemoveBuildingForPlayer(playerid, 13759, 1413.410, -804.742, 83.436, 0.250);
    RemoveBuildingForPlayer(playerid, 13831, 1413.410, -804.742, 83.436, 0.250);
    RemoveBuildingForPlayer(playerid, 13759, 1413.410, -804.742, 83.436, 0.250);
    return 1;
}